  var OPP_STAGES = [
    'Target', 'Working', 'Discovery', 'Proposal', 'Contracting',
    'Active Client', 'Expansion', 'Lost', 'Dormant'
  ];
  var ACTIVITY_TYPES = [
    'Email sent', 'Email received', 'Smartlead email sent', 'Smartlead reply',
    'Slack lead', 'Text message', 'Meeting', 'Call', 'Manual note',
