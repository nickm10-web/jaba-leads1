        bucket: 'schools',
        accountType: 'Current Client',
        stage: 'Active Client',
        owner: 'Jordon',
        priority: 'high',
        lastActivity: todayISO(),
        nextStep: 'Schedule next touch',
        notes: 'Preloaded current university client.'
