                    <div class="pipeline-card-company">${safeHtml(lead.company)}</div>
                    ${followUpHtml ? `<div class="pipeline-card-followup">${followUpHtml}</div>` : ''}
                  </div>
                `;
              }).join('')}
            </div>
          </div>
        `;
