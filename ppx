    // ===== KANBAN DRAG-DROP HANDLERS =====
    let draggedInboxCard = null;

    window.handleInboxDragStart = function(e) {
      draggedInboxCard = e.target.closest('.kanban-card');
      if (draggedInboxCard) {
        draggedInboxCard.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', draggedInboxCard.dataset.email || '');
      }
    };

    window.handleInboxDragEnd = function(e) {
      if (draggedInboxCard) draggedInboxCard.classList.remove('dragging');
      document.querySelectorAll('.kanban-col').forEach(col => col.classList.remove('drag-over'));
      draggedInboxCard = null;
    };

    window.handleInboxDragOver = function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      const col = e.target.closest('.kanban-col');
      if (col && draggedInboxCard) col.classList.add('drag-over');
    };

    window.handleInboxDragLeave = function(e) {
      const col = e.target.closest('.kanban-col');
      if (col) col.classList.remove('drag-over');
    };

    window.handleInboxDrop = function(e) {
      e.preventDefault();
      const targetCol = e.target.closest('.kanban-col');
      if (!draggedInboxCard || !targetCol) return;
      const newCategory = targetCol.dataset.category;
      const email = draggedInboxCard.dataset.email;
      if (!email || !newCategory) return;
      const entry = INBOX_EMAILS.find(en => en && en.email && en.email.toLowerCase() === email.toLowerCase());
      if (entry && categorizeEmail(entry) !== newCategory) {
        entry.pipelineOverride = newCategory;
        saveInboxOverrides();
        renderInbox();
      }
      targetCol.classList.remove('drag-over');
    };

    // ===== DISMISS KANBAN CARDS =====
    window.dismissInboxCard = function(email) {
      const entry = INBOX_EMAILS.find(e => e && e.email && e.email.toLowerCase() === email.toLowerCase());
      if (entry) {
        entry.dismissed = true;
        saveInboxOverrides();
        renderInbox();
      }
    };

    // ===== PERSIST INBOX OVERRIDES TO LOCALSTORAGE =====
    function saveInboxOverrides() {
      const overrides = {};
      INBOX_EMAILS.forEach(e => {
        if (e && e.email && (e.pipelineOverride || e.dismissed)) {
          overrides[e.email.toLowerCase()] = {};
          if (e.pipelineOverride) overrides[e.email.toLowerCase()].pipelineOverride = e.pipelineOverride;
          if (e.dismissed) overrides[e.email.toLowerCase()].dismissed = true;
        }
      });
      try { __memStore.setItem('inbox_overrides', JSON.stringify(overrides)); } catch(e) {}
    }

    function loadInboxOverrides() {
      try {
        const overrides = JSON.parse(__memStore.getItem('inbox_overrides') || '{}');
        INBOX_EMAILS.forEach(e => {
          if (e && e.email) {
            const o = overrides[e.email.toLowerCase()];
            if (o) {
              if (o.pipelineOverride) e.pipelineOverride = o.pipelineOverride;
              if (o.dismissed) e.dismissed = true;
            }
          }
        });
      } catch(e) {}
    }

    // ===== Daily Briefing (replaces the old dashboard) =====
    // Single landing surface that aggregates from leads + CRM + meetings +
    // tasks + inbox so missed follow-ups, unanswered emails, and overdue
    // tasks all surface in one place.

    const BR_STATE = { followUpsExpanded: false };

    // Days from `today` (YYYY-MM-DD) to `target` (YYYY-MM-DD).
    // Positive when target is in the future; negative when overdue.
    function briefingDaysBetween(today, target) {
      if (!today || !target) return 0;
      const t0 = new Date(today + 'T00:00:00');
      const t1 = new Date(target + 'T00:00:00');
      return Math.round((t1 - t0) / (1000 * 60 * 60 * 24));
    }

    function getTodayMeetings(today) {
      return (meetings || [])
        .filter(m => m && m.date === today)
        .sort((a, b) => (a.time || '').localeCompare(b.time || ''));
    }

    function getOverdueFollowUps(today) {
      const fromLeads = (leads || [])
        .filter(l => l && l.followUp && l.followUp < today && l.stage !== 'client')
        .map(l => ({
          kind: 'lead',
          name: l.company,
          sub: BUCKET_LABELS[l.bucket] || l.bucket,
          date: l.followUp,
          daysOverdue: -briefingDaysBetween(today, l.followUp),
          leadId: l.id
        }));
      const fromCrms = (window.jabaCustom && typeof window.jabaCustom.getCrmFollowUps === 'function')
        ? window.jabaCustom.getCrmFollowUps()
            .filter(f => f.daysFromToday < 0)
            .map(f => ({
              kind: 'crm',
              name: f.name,
              sub: f.source + (f.relationship ? ' \u00b7 ' + f.relationship : ''),
              date: f.date,
              daysOverdue: -f.daysFromToday,
              dataKey: f.dataKey,
              itemId: f.itemId
            }))
        : [];
      return fromLeads.concat(fromCrms).sort((a, b) => b.daysOverdue - a.daysOverdue);
    }

    function getNeedsResponseEmails() {
      if (typeof INBOX_EMAILS === 'undefined' || !Array.isArray(INBOX_EMAILS)) return [];
      return INBOX_EMAILS
        .filter(e => e && !e.dismissed && categorizeEmail(e) === 'needs_response')
        .sort((a, b) => (b.daysSince || 0) - (a.daysSince || 0));
    }

    function getDueOrOverdueTasks(today) {
      return (tasks || [])
        .filter(t => t && t.status !== 'done' && t.dueDate && t.dueDate <= today)
        .sort((a, b) => (a.dueDate || '').localeCompare(b.dueDate || ''));
    }

    function renderBriefingMeetings(items) {
      const list = document.getElementById('brMeetingsList');
      const count = document.getElementById('brMeetingsCount');
      const footer = document.getElementById('brMeetingsFooter');
      if (!list) return;
      count.textContent = items.length;
      if (items.length === 0) {
        list.innerHTML = '<div class="briefing-empty">No meetings today.</div>';
        footer.innerHTML = '';
        return;
      }
      const shown = items.slice(0, 5);
      list.innerHTML = shown.map(m => {
        const checklist = m.prepChecklist || [];
        const done = checklist.filter(c => c.done).length;
        const total = checklist.length;
        const prepStatus = total > 0 ? done + '/' + total + ' prep' : 'no prep checklist';
        const time = m.time ? safeHtml(m.time) : '(no time)';
        const attendees = (m.attendees || []).slice(0, 2).join(', ');
        return '<div class="briefing-item" onclick="openMeetingDetail(' + m.id + ')">' +
          '<div class="briefing-item-main">' +
            '<div class="briefing-item-title">' + safeHtml(m.company || '(no company)') +
              (attendees ? ' \u00b7 ' + safeHtml(attendees) : '') + '</div>' +
            '<div class="briefing-item-sub">' + time + ' \u00b7 ' + prepStatus + '</div>' +
          '</div>' +
        '</div>';
      }).join('');
      footer.innerHTML = items.length > 5
        ? '<a onclick="switchSection(\'meetings\')">Show all ' + items.length + ' in Meetings &rarr;</a>'
        : '';
    }

    function renderBriefingFollowUps(items) {
      const list = document.getElementById('brFollowUpsList');
