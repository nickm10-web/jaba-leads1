    function mergeCachedGmailIntoInbox() {
      const myEmail = 'jordon@jaba.ai';
      Object.values(gmailThreadCache).forEach(thread => {
        if (!thread.email || thread.email.toLowerCase() === myEmail) return;
        if (thread.email.includes('noreply') || thread.email.includes('no-reply') || thread.email.includes('calendar-notification')) return;

        const existingIdx = INBOX_EMAILS.findIndex(e => e && e.email && e.email.toLowerCase() === thread.email.toLowerCase());
        const msgs = (thread.messages || []).sort((a, b) => b.timestamp - a.timestamp);
        if (msgs.length === 0) return;
        const latest = msgs[0];
        const daysSince = Math.floor((Date.now() - latest.timestamp) / (1000 * 60 * 60 * 24));
        const latestSent = msgs.find(m => m.isSent);
        const latestReceived = msgs.find(m => !m.isSent);

        let status = 'pending';
        let note = '';
        if (latestReceived && (!latestSent || latestReceived.timestamp > latestSent.timestamp)) {
          // They replied last — ball in our court, needs response
          status = 'replied';
          note = 'They replied. Ball in our court.';
        } else if (latestSent && (!latestReceived || latestSent.timestamp > latestReceived.timestamp)) {
          // We sent last — check how long ago
          const daysSinceSent = Math.floor((Date.now() - latestSent.timestamp) / (1000 * 60 * 60 * 24));
          status = daysSinceSent >= 4 ? 'overdue' : 'pending';
          note = daysSinceSent >= 4 ? ('No reply in ' + daysSinceSent + ' days. Needs follow-up.') : 'Sent, waiting for reply.';
        }

        const entry = {
          company: thread.company || thread.email.split('@')[1]?.split('.')[0] || '',
          contact: thread.contact || '',
          email: thread.email,
          subject: latest.subject || '(no subject)',
          sentDate: new Date(latest.timestamp).toISOString().split('T')[0],
          status, daysSince, note,
          live: true,
          threadId: thread.threadId,
          msgCount: msgs.length
        };

        if (existingIdx >= 0) {
          // Preserve manual notes/categories but update dates
          const existing = INBOX_EMAILS[existingIdx];
          if (existing.category) entry.category = existing.category;
          if (existing.note && !existing.live) entry.note = existing.note;
          // Clear manual override if status changed (new message arrived)
          if (existing.status !== entry.status) {
            delete existing.pipelineOverride;
            delete existing.dismissed;
          } else {
            if (existing.pipelineOverride) entry.pipelineOverride = existing.pipelineOverride;
            if (existing.dismissed) entry.dismissed = existing.dismissed;
          }
          INBOX_EMAILS[existingIdx] = { ...existing, ...entry, note: existing.note && !existing.live ? existing.note : entry.note };
        } else {
          INBOX_EMAILS.push(entry);
        }
      });
    }

    async function fetchGmailEmails() {
      if (!gmailAccessToken) return;
      try {
        document.getElementById('gmailStatus').style.display = 'inline';
        document.getElementById('gmailStatus').style.color = '#fdcb6e';
        document.getElementById('gmailStatus').textContent = 'Syncing...';

        // Fetch sent + inbox messages (last 30 days)
        const [sentRes, inboxRes] = await Promise.all([
          fetch('https://gmail.googleapis.com/gmail/v1/users/me/messages?maxResults=50&q=in:sent newer_than:30d', {
            headers: { 'Authorization': 'Bearer ' + gmailAccessToken }
          }),
          fetch('https://gmail.googleapis.com/gmail/v1/users/me/messages?maxResults=50&q=in:inbox newer_than:30d', {
            headers: { 'Authorization': 'Bearer ' + gmailAccessToken }
          })
        ]);

        if (sentRes.status === 401 || inboxRes.status === 401) {
          console.log('Gmail 401 - attempting silent refresh...');
          gmailAccessToken = null;
          __memStore.removeItem('gmail_access_token');
          document.getElementById('gmailStatus').style.color = '#fdcb6e';
          document.getElementById('gmailStatus').textContent = 'Refreshing token...';
          silentRefreshGmail();
          return;
        }

        const [sentData, inboxData] = await Promise.all([sentRes.json(), inboxRes.json()]);
        const allMsgIds = new Set();
        (sentData.messages || []).forEach(m => allMsgIds.add(m.id));
        (inboxData.messages || []).forEach(m => allMsgIds.add(m.id));

        // Fetch full message details (with snippet for thread view)
        const msgIds = [...allMsgIds].slice(0, 100);
        const allMessages = [];
        for (let i = 0; i < msgIds.length; i += 10) {
          const batch = msgIds.slice(i, i + 10);
          const details = await Promise.all(batch.map(id =>
            fetch(`https://gmail.googleapis.com/gmail/v1/users/me/messages/${id}?format=metadata&metadataHeaders=From&metadataHeaders=To&metadataHeaders=Subject&metadataHeaders=Date`, {
              headers: { 'Authorization': 'Bearer ' + gmailAccessToken }
            }).then(r => r.json()).catch(() => null)
          ));
          allMessages.push(...details.filter(Boolean));
        }

        // Group into threads with full message data
        const threads = {};
        const myEmail = 'jordon@jaba.ai';
        allMessages.forEach(msg => {
          const tid = msg.threadId;
          if (!threads[tid]) threads[tid] = { threadId: tid, messages: [], contact: '', email: '', company: '' };
          const headers = {};
          (msg.payload?.headers || []).forEach(h => { headers[h.name] = h.value; });
          const isSent = (msg.labelIds || []).includes('SENT');
          threads[tid].messages.push({
            id: msg.id,
            from: headers['From'] || '',
            to: headers['To'] || '',
            subject: headers['Subject'] || '',
            timestamp: parseInt(msg.internalDate) || 0,
            isSent,
            snippet: msg.snippet || '',
            labels: msg.labelIds || []
          });
        });

        // Set contact/company for each thread
        Object.values(threads).forEach(thread => {
          const msgs = thread.messages.sort((a, b) => b.timestamp - a.timestamp);
          // Find the other party
          const sent = msgs.find(m => m.isSent);
          const received = msgs.find(m => !m.isSent);
          let parsed;
          if (sent) { parsed = parseContact(sent.to || ''); }
          else if (received) { parsed = parseContact(received.from || ''); }
          if (parsed && parsed.email.toLowerCase() !== myEmail) {
            thread.contact = parsed.name;
            thread.email = parsed.email;
          } else if (received) {
            parsed = parseContact(received.from || '');
            thread.contact = parsed.name;
            thread.email = parsed.email;
          }
          // Company from domain or existing INBOX_EMAILS match
          const existing = INBOX_EMAILS.find(e => e && e.email && thread.email && e.email.toLowerCase() === thread.email.toLowerCase());
          if (existing) {
            thread.company = existing.company;
            thread.contact = existing.contact || thread.contact;
          } else {
            const dom = (thread.email || '').split('@')[1] || '';
            thread.company = dom.split('.')[0];
            thread.company = thread.company.charAt(0).toUpperCase() + thread.company.slice(1);
          }
        });

        // Update cache and merge into INBOX_EMAILS
        gmailThreadCache = threads;
        mergeCachedGmailIntoInbox();

        // Save threads to Firebase (persist across sessions and token drops)
        const cacheForFirebase = {};
        Object.entries(threads).forEach(([tid, thread]) => {
          if (!thread.email || thread.email.toLowerCase() === myEmail) return;
          if (thread.email.includes('noreply') || thread.email.includes('no-reply') || thread.email.includes('calendar-notification') || thread.email.includes('notifications')) return;
          cacheForFirebase[tid] = {
            threadId: tid,
            contact: thread.contact,
            email: thread.email,
            company: thread.company,
            messages: thread.messages.map(m => ({
              id: m.id, from: m.from, to: m.to, subject: m.subject,
              timestamp: m.timestamp, isSent: m.isSent, snippet: m.snippet
            }))
          };
        });
        db.ref('gmail_threads').set({ lastSync: Date.now(), threads: cacheForFirebase });

        document.getElementById('gmailStatus').style.color = '#00b894';
        document.getElementById('gmailStatus').textContent = 'Synced ' + Object.keys(cacheForFirebase).length + ' threads • ' + new Date().toLocaleTimeString();

        renderInbox();
        if (currentSection === 'dashboard') renderDashboard();

      } catch (err) {
        console.error('Gmail fetch error:', err);
        document.getElementById('gmailStatus').style.display = 'inline';
        document.getElementById('gmailStatus').style.color = '#ff6b6b';
        document.getElementById('gmailStatus').textContent = 'Sync error: ' + err.message;
      }
    }

    // Open thread detail view
    let activeThreadId = null;

    // Generate a smart draft based on conversation context
    function generateSmartDraft(thread) {
      const msgs = (thread.messages || []).sort((a, b) => b.timestamp - a.timestamp);
      const latest = msgs[0];
      const contact = cleanContactName(thread.contact, thread.email);
      const firstName = contact.split(' ')[0];
      const latestReceived = msgs.find(m => !m.isSent);
      const latestSent = msgs.find(m => m.isSent);
      const daysSince = latest ? Math.floor((Date.now() - latest.timestamp) / (1000*60*60*24)) : 0;

      // If they replied last (ball in our court) - respond
      if (latestReceived && (!latestSent || latestReceived.timestamp > latestSent.timestamp)) {
        const snippet = (latestReceived.snippet || '').toLowerCase();
        if (snippet.includes('meeting') || snippet.includes('call') || snippet.includes('schedule') || snippet.includes('calendar')) {
          return `Hey ${firstName},\n\nThat works for me. I'll send over an invite now.\n\nJordon`;
        }
        if (snippet.includes('interested') || snippet.includes('love to') || snippet.includes('let\'s do it') || snippet.includes('sounds good')) {
          return `Hey ${firstName},\n\nAwesome, glad to hear it. Let me know when you have some time this week and I'll walk you through everything.\n\nJordon`;
        }
        if (snippet.includes('question') || snippet.includes('how does') || snippet.includes('tell me more')) {
          return `Hey ${firstName},\n\nGreat question. Would be easier to show you than explain over email. Got any time for a quick call this week?\n\nJordon`;
        }
        return `Hey ${firstName},\n\nAppreciate the reply. `;
      }

      // If we sent last and need to follow up
      if (daysSince >= 4) {
        return `Hey ${firstName},\n\nJust wanted to circle back on this. Let me know if you have any questions or if there's a better time to connect.\n\nJordon`;
      }

      // Default new reply
      return `Hey ${firstName},\n\n`;
    }

    // Extract plain text body from Gmail message MIME parts
    function extractBodyFromParts(payload) {
      if (!payload) return '';
      // Direct body (simple messages)
      if (payload.body && payload.body.data) {
        try {
          return atob(payload.body.data.replace(/-/g, '+').replace(/_/g, '/'));
        } catch(e) { return ''; }
      }
      // Multipart — recurse through parts, prefer text/plain
      if (payload.parts) {
        // First pass: look for text/plain
        for (const part of payload.parts) {
          if (part.mimeType === 'text/plain' && part.body && part.body.data) {
            try {
              return atob(part.body.data.replace(/-/g, '+').replace(/_/g, '/'));
            } catch(e) {}
          }
        }
        // Second pass: recurse into nested multipart
        for (const part of payload.parts) {
          const nested = extractBodyFromParts(part);
          if (nested) return nested;
        }
      }
      return '';
    }

