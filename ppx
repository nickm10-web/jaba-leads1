          </div>
          <div class="kanban-col-body">`;
        col.items.forEach(item => {
          const lead = findLead(item.company);
          const dc = daysClass(item.daysSince);
          const safeEmail = (item.email || '').replace(/'/g, "\\'");
          const safeThreadId = (item.threadId || '').replace(/'/g, "\\'");
