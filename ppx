    // Render pipeline/kanban view
    function renderPipeline() {
      const displayed = getDisplayLeads();
      const pipelineView = document.getElementById('pipelineView');

      // Group leads by stage
      const stageOrder = ['lead', 'contacted', 'meeting_scheduled', 'scrape', 'building', 'auditing', 'ready', 'meeting_complete', 'report_sent', 'contract_sent', 'client', 'onhold'];
      const leadsByStage = {};

      stageOrder.forEach(stage => {
        leadsByStage[stage] = displayed.filter(lead => lead.stage === stage);
      });

      // Build columns HTML
      let html = '';
      stageOrder.forEach(stage => {
        const leads = leadsByStage[stage];
        const count = leads.length;

        html += `
          <div class="pipeline-column" data-stage="${stage}" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)">
            <div class="pipeline-column-header">
              <h3>${STAGE_LABELS[stage]}</h3>
              <span class="pipeline-column-count">${count}</span>
            </div>
            <div class="pipeline-column-content">
              ${leads.map(lead => {
                const colors = BRAND_COLORS[lead.company] || ['#a29bfe', '#fff'];
                const logoHtml = lead.domain
                  ? `<img src="${safeHtml(lead.domain)}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" style="width:100%;height:100%;object-fit:cover;">`
                  : '';
                const initialsHtml = `<div class="pipeline-card-initials" style="background:${colors[0]};color:${colors[1]}; ${lead.domain ? 'display:none;' : ''}">${safeHtml(getInitials(lead.company))}</div>`;

                const followUpHtml = renderFollowUp(lead.followUp);

                return `
                  <div class="pipeline-card" draggable="true" ondragstart="handleDragStart(event)" ondragend="handleDragEnd(event)" data-lead-id="${lead.id}" onclick="openDetailPanel(${lead.id})" role="listitem" aria-label="${safeHtml(lead.company)}">
