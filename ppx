    function defaultSchools() {
      return (window.D1_SCHOOLS_DATA || []).map(school => ({ ...school }));
    }

    function normalizeSchoolName(name) {
      let normalized = String(name || '')
        .toLowerCase()
        .replace(/&/g, ' and ')
        .replace(/\//g, ' ')
        .replace(/[().,''-]/g, ' ')
        .replace(/\bthe\b/g, ' ')
        .replace(/\buniversity of\b/g, ' ')
        .replace(/\buniversity\b/g, ' ')
        .replace(/\bcollege of\b/g, ' ')
        .replace(/\bsaint\b/g, 'st')
        .replace(/\bst\.\b/g, 'st')
        .replace(/\s+/g, ' ')
        .trim();

      return SCHOOL_ALIASES[normalized]
        ? SCHOOL_ALIASES[normalized].toLowerCase()
        : normalized;
    }

    function getSchoolConferenceList(grouped) {
      const ordered = [];
      const seen = new Set();
      (CONFERENCE_ORDER[grouped[0]?.subdivisionGroup] || []).forEach(conf => {
        if (grouped.some(item => item.conference === conf)) {
          ordered.push(conf);
          seen.add(conf);
        }
      });
      grouped
        .map(item => item.conference)
        .filter((conf, index, arr) => conf && arr.indexOf(conf) === index && !seen.has(conf))
        .sort((a, b) => a.localeCompare(b))
        .forEach(conf => ordered.push(conf));
      return ordered;
    }

    function getSchoolLogo(record) {
      if (record.logo) return record.logo;
      if (record.lead?.domain) return record.lead.domain;
      return '';
    }

    function getSchoolInitials(name) {
      return String(name || '')
        .split(' ')
        .filter(Boolean)
        .slice(0, 2)
        .map(word => word[0])
        .join('')
        .toUpperCase() || '?';
    }

    function getSchoolStatusClass(stage, isUnworked) {
      if (isUnworked) return 'unworked';
      if (stage === 'client') return 'client';
      return '';
    }

    function getSchoolHeat(record) {
      if (record.stage === 'client') {
        return { key: 'green', label: 'Green', reason: 'Client' };
      }

      if (['meeting_scheduled', 'meeting_complete', 'contract_sent', 'ready', 'report_sent', 'building', 'auditing', 'announcement_working', 'announcement_sent', 'announcement_approved'].includes(record.stage)) {
        return { key: 'green', label: 'Green', reason: 'Hot' };
      }

      if (record.followUp || record.emailItems.length > 0 || record.meetings.length > 0 || record.tasks.some(task => task.status !== 'done') || ['contacted', 'lead', 'scrape'].includes(record.stage)) {
        return { key: 'yellow', label: 'Yellow', reason: 'Waiting' };
      }

      return { key: 'red', label: 'Red', reason: 'Cold' };
    }

    function getStageStyle(stage, isUnworked) {
      if (isUnworked) return 'background:rgba(139,148,158,0.14);color:var(--text-secondary);';
      const stageColors = {
        lead: '#a29bfe',
        contacted: '#74b9ff',
        meeting_scheduled: '#81ecec',
        scrape: '#ffeaa7',
        building: '#fab1a0',
        auditing: '#d6c5ff',
        ready: '#55efc4',
        meeting_complete: '#00b894',
        report_sent: '#74b9ff',
        contract_sent: '#fd79a8',
        client: '#E2F500',
        onhold: '#8b949e'
      };
      const bg = stageColors[stage] || '#30363d';
      const fg = stage === 'client' || stage === 'scrape' ? '#000' : '#fff';
      return `background:${bg};color:${fg};`;
    }

    function getBestSchoolLeadMatch(school) {
      const aliases = [school.schoolName, ...(school.aliases || [])].map(normalizeSchoolName);
      const schoolNames = new Set(aliases);
      const schoolLeads = leads.filter(lead => lead.bucket === 'schools');
      return schoolLeads.find(lead => schoolNames.has(normalizeSchoolName(lead.company))) || null;
    }

    function getSchoolEmails(school, lead) {
      const aliases = [school.schoolName, ...(school.aliases || []), lead?.company].filter(Boolean).map(normalizeSchoolName);
      const seen = new Set();
      return INBOX_EMAILS.filter(item => {
        const normalizedCompany = normalizeSchoolName(item.company || '');
        return aliases.some(alias => normalizedCompany === alias);
      }).filter(item => {
        const key = `${item.email}-${item.subject}`;
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
    }

    function getSchoolThreads(emailItems) {
      const threadIds = new Set(emailItems.map(item => item.threadId).filter(Boolean));
      return Object.values(gmailThreadCache || {}).filter(thread => threadIds.has(thread.threadId));
    }

    function getSchoolMeetings(school, lead) {
      const aliases = [school.schoolName, ...(school.aliases || []), lead?.company].filter(Boolean).map(normalizeSchoolName);
      return meetings.filter(meeting => {
        if (lead && meeting.linkedLeadId === lead.id) return true;
        const company = normalizeSchoolName(meeting.company || '');
        return aliases.some(alias => company === alias);
      });
    }

    function getSchoolTasks(lead) {
      if (!lead) return [];
      return tasks.filter(task => task.linkedLeadId === lead.id);
    }

    function getSchoolContextPreview(record, mode) {
      const upcomingMeeting = record.meetings
        .filter(meeting => meeting.date)
        .sort((a, b) => a.date.localeCompare(b.date))[0];
      const openTask = record.tasks.find(task => task.status !== 'done');

      if (mode === 'crm') {
        if (record.followUp) return `Follow-up ${record.followUp}`;
        if (record.contacts.length) return `${record.contacts.length} contact${record.contacts.length === 1 ? '' : 's'} linked`;
        if (openTask) return openTask.title;
        return record.isUnworked ? 'No CRM activity yet' : 'CRM record active';
      }

      if (upcomingMeeting) return `Meeting ${upcomingMeeting.date}${upcomingMeeting.time ? ' • ' + upcomingMeeting.time : ''}`;
      if (record.lead?.context) return record.lead.context.split('|')[0].trim().slice(0, 90);
      if (record.emailItems.length) return `${record.emailItems.length} related email${record.emailItems.length === 1 ? '' : 's'} tracked`;
      return record.isUnworked ? 'No activity yet' : 'Open school record';
    }

    function buildSchoolBoardData() {
      return defaultSchools().map(school => {
        const lead = getBestSchoolLeadMatch(school);
        const emailItems = getSchoolEmails(school, lead);
        const relatedMeetings = getSchoolMeetings(school, lead);
        const relatedTasks = getSchoolTasks(lead);
        const relatedThreads = getSchoolThreads(emailItems);
        const isUnworked = !lead;
        const stage = lead?.stage || 'unworked';
        return {
          schoolId: school.id,
          schoolName: school.schoolName,
          conference: school.conference,
          conferenceFull: school.conferenceFull,
          subdivisionGroup: school.subdivisionGroup,
          logo: school.logo,
          lead,
          stage,
          displayStatus: isUnworked ? 'Unworked' : (STAGE_LABELS[stage] || 'Active'),
          followUp: lead?.followUp || '',
          contacts: lead?.contacts || [],
          tasks: relatedTasks,
          meetings: relatedMeetings,
          inboxThreads: relatedThreads,
          emailItems,
          isUnworked,
          heat: null,
          contextPreview: '',
          aliases: school.aliases || []
        };
      }).map(record => ({
        ...record,
        heat: getSchoolHeat(record),
        contextPreview: getSchoolContextPreview(record, currentSchoolView)
      }));
    }

    function renderSchoolsFilterChips() {
      const chips = ['All', 'Power 4', 'Group of 5', 'Other D1'];
      const container = document.getElementById('schoolsFilterChips');
      container.innerHTML = chips.map(chip => `
        <button class="schools-filter-chip ${currentSchoolFilter === chip ? 'active' : ''}" onclick="setSchoolsFilter('${chip}')">${chip}</button>
      `).join('');
    }

    function renderConferenceSection(conferenceName, schoolRecords) {
      const activeCount = schoolRecords.filter(record => !record.isUnworked).length;
      const clientCount = schoolRecords.filter(record => record.stage === 'client').length;
      return `
        <div class="conference-section">
          <div class="conference-section-header">
            <div class="conference-title-block">
              <div class="conference-name">${escapeHtml(conferenceName)}</div>
              <span class="conference-badge">${schoolRecords.length} schools</span>
            </div>
            <div class="conference-metrics">
              <span class="conference-metric">${activeCount} active</span>
              <span class="conference-metric">${clientCount} clients</span>
            </div>
          </div>
          <div class="schools-grid">
            ${schoolRecords.map(record => {
              const logo = getSchoolLogo(record);
              const statusClass = getSchoolStatusClass(record.stage, record.isUnworked);
              const cardClass = `${record.isUnworked ? 'unworked' : ''} ${record.stage === 'client' ? 'client' : ''}`.trim();
              return `
                <div class="school-card ${cardClass}" onclick="openSchoolPanel('${record.schoolId}')">
                  <div class="school-card-header">
                    <div class="school-logo">
                      ${logo
                        ? `<img src="${escapeHtml(logo)}" alt="${escapeHtml(record.schoolName)} logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"><span style="display:none;align-items:center;justify-content:center;width:100%;height:100%;">${getSchoolInitials(record.schoolName)}</span>`
                        : getSchoolInitials(record.schoolName)}
                    </div>
                    <span class="school-conference-pill">${escapeHtml(record.conference)}</span>
                  </div>
                  <div class="school-name">${escapeHtml(record.schoolName)}</div>
                  <span class="school-heat ${record.heat.key}">
                    <span class="school-heat-dot" style="background:${record.heat.key === 'green' ? '#00b894' : record.heat.key === 'yellow' ? '#fdcb6e' : '#ff6b6b'}" role="img" aria-label="Heat: ${record.heat.key}"></span>
                    ${escapeHtml(record.heat.label)}
                  </span>
                  <span class="school-status ${statusClass}" style="${getStageStyle(record.stage, record.isUnworked)}">${escapeHtml(record.displayStatus)}</span>
                  <div class="school-context">${escapeHtml(record.contextPreview)}</div>
                  <div class="school-card-footer">
                    <span>${record.followUp ? `FU ${escapeHtml(record.followUp)}` : 'No follow-up'}</span>
                    <span>${record.contacts.length} contacts</span>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        </div>
      `;
    }

    window.setSchoolsFilter = function(filter) {
      currentSchoolFilter = filter;
      renderSchools();
    };

    window.setSchoolsView = function(mode) {
      currentSchoolView = mode;
      document.querySelectorAll('.schools-view-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.mode === mode);
      });
      renderSchools();
    };

    window.handleSchoolsSearch = function(value) {
      currentSchoolQuery = value.toLowerCase().trim();
      renderSchools();
    };

    function renderSchools() {
      renderSchoolsFilterChips();
      const records = buildSchoolBoardData();
      const filtered = records.filter(record => {
        const matchesFilter = currentSchoolFilter === 'All' || record.subdivisionGroup === currentSchoolFilter;
        const haystack = `${record.schoolName} ${record.conference} ${record.conferenceFull} ${(record.aliases || []).join(' ')}`.toLowerCase();
        const matchesSearch = !currentSchoolQuery || haystack.includes(currentSchoolQuery);
        return matchesFilter && matchesSearch;
      });

      const stats = {
        total: records.length,
        active: records.filter(record => !record.isUnworked).length,
        meetings: records.filter(record => record.meetings.length > 0).length,
        clients: records.filter(record => record.stage === 'client').length,
        untouched: records.filter(record => record.isUnworked).length
      };

      document.getElementById('schoolsStats').innerHTML = [
        ['Total D1 Schools', stats.total],
        ['Active CRM Records', stats.active],
        ['Schools with Meetings', stats.meetings],
        ['Clients', stats.clients],
        ['Untouched Schools', stats.untouched]
      ].map(([label, value]) => `
        <div class="schools-stat-card">
          <div class="schools-stat-value">${value}</div>
          <div class="schools-stat-label">${label}</div>
        </div>
      `).join('');

      const board = document.getElementById('schoolsBoard');
      if (filtered.length === 0) {
        board.innerHTML = '<div class="schools-empty">No schools match the current filters.</div>';
        return;
      }

      const groupHtml = CONFERENCE_GROUP_ORDER.map(group => {
        const grouped = filtered.filter(record => record.subdivisionGroup === group);
        if (grouped.length === 0) return '';
        const conferenceList = getSchoolConferenceList(grouped);
        const groupStats = {
          active: grouped.filter(record => !record.isUnworked).length,
          clients: grouped.filter(record => record.stage === 'client').length
        };
        return `
          <div class="schools-group">
            <div class="schools-group-header">
              <div class="schools-group-title">${group}</div>
              <div class="schools-group-meta">${grouped.length} schools • ${groupStats.active} active • ${groupStats.clients} clients</div>
            </div>
            ${conferenceList.map(conference => renderConferenceSection(conference, grouped.filter(record => record.conference === conference))).join('')}
          </div>
        `;
      }).join('');

      board.innerHTML = groupHtml;
    }

    window.openSchoolPanel = function(schoolId) {
      const record = buildSchoolBoardData().find(item => item.schoolId === schoolId);
      if (!record) return;

      const logo = getSchoolLogo(record);
      const relatedEmails = record.emailItems.slice(0, 5);
      const relatedMeetings = record.meetings.slice(0, 5);
      const relatedTasks = record.tasks.slice(0, 5);
      const lead = record.lead;

      const contactsHtml = record.contacts.length
        ? record.contacts.map(contact => `<div class="detail-contact-item"><div class="detail-contact-name">${escapeHtml(contact.split('(')[0].trim())}</div><div class="detail-contact-email">${escapeHtml(contact.includes('(') ? contact.split('(')[1].replace(')', '').trim() : '')}</div></div>`).join('')
        : '<div style="color:var(--text-secondary);font-size:13px;">No contacts yet</div>';

      const emailsHtml = relatedEmails.length
        ? relatedEmails.map(email => `<div class="related-email-item" onclick="switchSection('inbox')"><div class="related-email-contact">${escapeHtml(email.contact || email.company)}</div><div class="related-email-subject">${escapeHtml(email.subject || '')}</div><div class="related-email-date">${escapeHtml(email.sentDate || '')}</div></div>`).join('')
        : '<div style="color:var(--text-secondary);font-size:13px;">No related inbox activity</div>';

      const meetingsHtml = relatedMeetings.length
        ? relatedMeetings.map(meeting => `<div style="padding:10px;background:var(--bg-tertiary);border-radius:8px;font-size:12px;"><div style="font-weight:600;color:var(--text-primary);">${escapeHtml(meeting.company)}</div><div style="color:var(--text-secondary);margin-top:4px;">${escapeHtml(meeting.date || '')}${meeting.time ? ' • ' + escapeHtml(meeting.time) : ''}</div></div>`).join('')
        : '<div style="color:var(--text-secondary);font-size:13px;">No meetings scheduled</div>';

      const tasksHtml = relatedTasks.length
        ? relatedTasks.map(task => `<div style="padding:10px;background:var(--bg-tertiary);border-radius:8px;font-size:12px;"><div style="font-weight:600;color:var(--text-primary);">${escapeHtml(task.title)}</div><div style="color:var(--text-secondary);margin-top:4px;">${escapeHtml(task.dueDate || 'No due date')}</div></div>`).join('')
        : '<div style="color:var(--text-secondary);font-size:13px;">No linked tasks</div>';

      const primaryActions = lead
        ? `
          <button class="btn btn-secondary" onclick="openDetailPanel(${lead.id})">Open Lead</button>
          <button class="btn btn-primary" onclick="openEditModal(${lead.id})">Edit Lead</button>
          <button class="btn btn-secondary" onclick="addMeetingForSchool('${record.schoolId}')">Add Meeting</button>
          <button class="btn btn-secondary" onclick="addTaskForSchool('${record.schoolId}')">Add Task</button>
        `
        : `
          <button class="btn btn-primary" onclick="createLeadFromSchool('${record.schoolId}', true)">Create Lead</button>
          <button class="btn btn-secondary" onclick="addNoteForSchool('${record.schoolId}')">Add Note</button>
        `;

      const html = `
        <div class="detail-logo-large">
          ${logo
            ? `<img src="${escapeHtml(logo)}" alt="${escapeHtml(record.schoolName)} logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"><div style="display:none;align-items:center;justify-content:center;height:100%;font-size:28px;font-weight:700;">${getSchoolInitials(record.schoolName)}</div>`
            : `<div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:28px;font-weight:700;">${getSchoolInitials(record.schoolName)}</div>`}
        </div>
        <div class="detail-company-name">${escapeHtml(record.schoolName)}</div>
        <div class="detail-pills">
          <span class="bucket-pill bucket-schools">Schools</span>
          <span class="school-heat ${record.heat.key}">
            <span class="school-heat-dot" style="background:${record.heat.key === 'green' ? '#00b894' : record.heat.key === 'yellow' ? '#fdcb6e' : '#ff6b6b'}"></span>
            ${escapeHtml(record.heat.label)} • ${escapeHtml(record.heat.reason)}
          </span>
          <span class="stage-pill ${record.isUnworked ? '' : `stage-${record.stage}`}" style="${getStageStyle(record.stage, record.isUnworked)}">${escapeHtml(record.displayStatus)}</span>
          <span class="bucket-pill" style="background:rgba(226,245,0,0.12);color:var(--accent);">${escapeHtml(record.conference)}</span>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Follow-Up</div>
          <div class="detail-notes">${record.followUp ? escapeHtml(record.followUp) : 'No follow-up set'}</div>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Contacts</div>
          <div class="detail-contacts-list">${contactsHtml}</div>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Context / Notes</div>
          <div class="detail-notes">${lead?.context ? escapeHtml(lead.context) : 'No notes yet'}</div>
        </div>

        <div class="related-emails-section">
          <div class="detail-section-title">Related Inbox Activity</div>
          ${emailsHtml}
        </div>

        <div class="related-emails-section">
          <div class="detail-section-title">Related Meetings</div>
          <div style="display:flex;flex-direction:column;gap:8px;">${meetingsHtml}</div>
        </div>

        <div class="related-emails-section">
          <div class="detail-section-title">Related Tasks</div>
          <div style="display:flex;flex-direction:column;gap:8px;">${tasksHtml}</div>
        </div>

        <div class="school-panel-actions">
          ${primaryActions}
        </div>
      `;

      document.getElementById('detailPanelContent').innerHTML = html;
      document.getElementById('detailPanel').classList.add('active');
    };

    window.createLeadFromSchool = function(schoolId, openEditor = false) {
      const school = defaultSchools().find(item => item.id === schoolId);
      if (!school) return null;
      const existingLead = getBestSchoolLeadMatch(school);
      if (existingLead) {
        if (openEditor) openEditModal(existingLead.id);
        return existingLead;
      }
      const newLeadId = Math.max(...leads.map(lead => lead.id || 0), 0) + 1;
      const lead = {
        id: newLeadId,
        company: school.schoolName,
        bucket: 'schools',
        stage: 'lead',
        followUp: '',
        contacts: [],
        context: '',
        domain: school.logo || ''
      };
      leads.push(lead);
      saveleads();
      populateLeadLinker();
      renderSchools();
      if (openEditor) {
        closeDetailPanel();
        openEditModal(lead.id);
      } else {
        openSchoolPanel(schoolId);
      }
      return lead;
    };

    window.addNoteForSchool = function(schoolId) {
      createLeadFromSchool(schoolId, true);
    };

    window.addTaskForSchool = function(schoolId) {
      const lead = createLeadFromSchool(schoolId, false);
      switchSection('tasks');
      const form = document.getElementById('taskFullForm');
      if (form.style.display === 'none') {
        toggleTaskForm();
      }
      document.getElementById('taskLinkedLead').value = lead.id;
      document.getElementById('taskTitle').value = `Follow up with ${lead.company}`;
      document.getElementById('taskTitle').focus();
      closeDetailPanel();
    };

    window.addMeetingForSchool = function(schoolId) {
      const lead = createLeadFromSchool(schoolId, false);
      switchSection('meetings');
      showQuickAddForm(getTodayDate());
      setTimeout(() => {
        if (document.getElementById('qCompany')) {
          document.getElementById('qCompany').value = lead.company;
          document.getElementById('qType').focus();
        }
      }, 0);
      closeDetailPanel();
    };

    // Start
    init();
  </script>
<script src="jaba-custom.js"></script>
<script src="jaba-crm-mvp.js"></script>
<script>
  /* Inbox sync client — calls the backend /api/sync-inbox endpoint and
   * updates the header status pill. The actual Gmail call happens
   * server-side; this script only triggers the sync and renders status.
   *
   * No localStorage / sessionStorage / IndexedDB — recent-sync gating uses
   * an in-memory module variable plus the server's own throttle.
   */
  (function () {
    'use strict';
    var lastClientRun = 0;
    var inFlight = false;

    // Resolve the backend base URL.
    //
    // In a deployed preview the website-building harness rewrites the
    // literal string `__PORT_5000__` to a backend-proxy path that forwards
    // requests to the locally-running Node server on port 5000. If the
    // placeholder is never rewritten (e.g. running `npm start` locally
    // where the same Node process serves both the static files and the
    // /api routes) we strip it and fall back to a relative path so the
    // browser hits the same origin.
    function apiBase() {
      var raw = '__PORT_5000__';
      // Detect un-rewritten placeholder. We split it across concatenation
      // so this comparison string itself isn't rewritten by the harness.
      var sentinel = '__' + 'PORT_5000__';
      if (raw === sentinel) return '';
      return raw.replace(/\/+$/, '');
    }

    function apiUrl(path) {
      return apiBase() + path;
    }

    function $(id) { return document.getElementById(id); }

    function fmtTime(iso) {
      if (!iso) return '';
      try {
        var d = new Date(iso);
        var hh = String(d.getHours()).padStart(2, '0');
        var mm = String(d.getMinutes()).padStart(2, '0');
        return hh + ':' + mm;
      } catch (e) { return ''; }
    }

    function setStatus(text, color) {
      var el = $('inboxSyncStatus');
      if (!el) return;
      el.textContent = text || '';
      if (color) el.style.color = color;
      // Hide the pill entirely when there's no status to show, so the
      // header doesn't render an empty rounded chip in the deployed view.
      el.style.display = text ? 'inline-flex' : 'none';
    }

    function summarize(result) {
      if (!result || !result.ok) return 'Inbox sync failed';
      if (result.skipped) return 'Inbox synced ' + fmtTime(result.lastSync) + ' (cached)';
      var c = result.counts || {};
      return 'Inbox synced ' + fmtTime(result.finishedAt) +
        ' · ' + (c.imported || 0) + ' imported, ' +
        (c.skipped || 0) + ' skipped, ' +
        (c.tasksCreated || 0) + ' tasks';
    }

    async function run(opts) {
      if (inFlight) return;
      inFlight = true;
      var btn = $('inboxSyncBtn');
      if (btn) { btn.disabled = true; btn.textContent = 'Syncing…'; }
      setStatus('Inbox: syncing…', '#fdcb6e');
      try {
        var r = await fetch(apiUrl('/api/sync-inbox'), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(opts || {})
        });
        var data = await r.json();
        if (!r.ok || !data.ok) {
          setStatus('Inbox sync error: ' + ((data && data.error) || r.status), '#ff6b6b');
          return data;
        }
        lastClientRun = Date.now();
        setStatus(summarize(data), '#bbb');
        return data;
      } catch (e) {
        setStatus('Inbox sync error: ' + (e && e.message ? e.message : 'network'), '#ff6b6b');
      } finally {
        inFlight = false;
        if (btn) { btn.disabled = false; btn.textContent = 'Sync Inbox'; }
      }
    }

    async function loadStatus() {
      try {
        var r = await fetch(apiUrl('/api/sync-inbox/status'));
        var data = await r.json();
        if (data && data.ok && data.meta && data.meta.lastSync) {
          setStatus(summarize({
            ok: true,
            skipped: false,
            finishedAt: data.meta.lastSync,
            counts: (data.meta.lastResult && data.meta.lastResult.counts) || {}
          }), '#bbb');
          return data.meta;
        }
        setStatus('Inbox: never synced', '#bbb');
      } catch (e) {
        // Backend likely not running — leave default text.
      }
      return null;
    }

    async function maybeAutoSync() {
      var meta = await loadStatus();
      var ageMs = meta && meta.lastSync ? (Date.now() - Date.parse(meta.lastSync)) : Infinity;
      // If we haven't synced in the last 30 minutes, run one sync on load.
      // The server also has its own 5-minute throttle as a backstop.
      if (ageMs > 30 * 60 * 1000 && !inFlight) {
        run();
      }
    }

    window.jabaInboxSync = { run: run, loadStatus: loadStatus };

    // Defer auto-sync until after the page settles.
    if (document.readyState === 'complete') {
      setTimeout(maybeAutoSync, 1500);
    } else {
      window.addEventListener('load', function () { setTimeout(maybeAutoSync, 1500); });
    }
  })();
</script>
