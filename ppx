      const todayMeetings = getTodayMeetings(today);
      const overdueFollowUps = getOverdueFollowUps(today);
      const needsResponse = getNeedsResponseEmails();
      const dueTasks = getDueOrOverdueTasks(today);

      renderBriefingMeetings(todayMeetings);
      renderBriefingFollowUps(overdueFollowUps);
      renderBriefingEmails(needsResponse);
      renderBriefingTasks(dueTasks, today);

      if (window.jabaMvp && window.jabaMvp.renderDashboardSections) {
