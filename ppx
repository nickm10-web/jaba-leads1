    // Save lead
    function saveLead() {
      const company = document.getElementById('companyName').value.trim();
      const bucket = document.getElementById('bucket').value;
      const stage = document.getElementById('stage').value;
      const followUp = document.getElementById('followUp').value;
      const contacts = document.getElementById('contacts').value
        .split(',')
        .map(c => c.trim())
        .filter(c => c);
      const context = document.getElementById('context').value.trim();
      const domain = document.getElementById('domain').value.trim();

      if (!company || !bucket || !stage) {
        alert('Please fill in all required fields.');
        return;
      }

      // Validate follow-up date format
      if (followUp && !/^\d{4}-\d{2}-\d{2}$/.test(followUp)) {
        alert('Follow-up date must be in YYYY-MM-DD format.');
        return;
      }

      // Validate logo URL
      if (domain && !/^https?:\/\/.+/i.test(domain)) {
        alert('Logo URL must start with http:// or https://');
        return;
      }

      // Duplicate lead detection (skip if editing the same lead)
      const duplicate = leads.find(l =>
        l.company.toLowerCase() === company.toLowerCase() &&
        l.bucket === bucket &&
        l.id !== editingId
      );
      if (duplicate) {
        if (!confirm(`A lead for "${duplicate.company}" already exists in the ${BUCKET_LABELS[bucket]} bucket. Add anyway?`)) {
          return;
        }
      }

      if (editingId) {
        const lead = leads.find(l => l.id === editingId);
        if (lead) {
          lead.company = company;
          lead.bucket = bucket;
          lead.stage = stage;
          lead.followUp = followUp;
          lead.contacts = contacts;
          lead.context = context;
          lead.domain = domain;
        }
      } else {
        const id = Math.max(...leads.map(l => l.id), 0) + 1;
        leads.push({
          id,
          company,
          bucket,
          stage,
          followUp,
          contacts,
          context,
          domain
        });
      }

      saveleads();
      closeModal();
      renderView();
    }

