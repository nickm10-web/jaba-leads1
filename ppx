    // Decode HTML entities from Gmail snippets (fixes â and other garbled chars)
    function decodeHtmlEntities(str) {
      if (!str) return '';
      const el = document.createElement('textarea');
      el.innerHTML = str;
      return el.value;
    }

    // Escape text for safe HTML insertion (prevents < > " ' from breaking DOM)
    function safeHtml(str) {
      if (!str) return '';
      return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    // Safe logo HTML: uses hidden fallback sibling instead of innerHTML in onerror
    function buildLogoHtml(src, company, colors) {
      if (!colors) colors = ['#a29bfe', '#fff'];
      const initials = safeHtml(getInitials(company));
      if (!src) {
        return `<div class="logo-initials" style="background:${colors[0]};color:${colors[1]}">${initials}</div>`;
      }
      return `<img class="logo-img" src="${safeHtml(src)}" alt="${safeHtml(company)} logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"><div class="logo-initials" style="background:${colors[0]};color:${colors[1]};display:none;">${initials}</div>`;
    }

    // Decode Gmail entities then escape for safe HTML insertion
    function safeDecode(str) {
      return safeHtml(decodeHtmlEntities(str));
    }

    // Gmail thread cache (persisted to Firebase)
    let gmailThreadCache = {}; // threadId -> { messages: [...], contact, email, company, subject }

    function parseContact(headerStr) {
      // Handle multiple recipients - take the first one
      const firstRecipient = headerStr.split(',')[0].trim();
      const match = firstRecipient.match(/"?([^"<]+)"?\s*<([^>]+)>/);
      if (match) return { name: match[1].trim(), email: match[2].trim() };
      const em = firstRecipient.trim();
      return { name: em.split('@')[0], email: em };
    }

    // Load cached Gmail data from Firebase on startup
    // Real-time listener: auto-updates when Apps Script pushes new data
    function loadGmailCache() {
      db.ref('gmail_threads').on('value', snap => {
        const data = snap.val();
        if (data) {
          gmailThreadCache = data.threads || {};
          mergeCachedGmailIntoInbox();
          renderInbox();
          if (currentInboxView === 'gmail') renderGmailInbox();
          // Also refresh the Daily Briefing if it's the active surface,
          // so its "Needs Response" card reflects new/replied emails.
          if (currentSection === 'dashboard') renderDashboard();

          const threadCount = Object.keys(gmailThreadCache).length;
          const lastSync = data.lastSync ? new Date(data.lastSync) : null;
          const statusEl = document.getElementById('gmailStatus');
          const dotEl = document.getElementById('gmailSyncDot');

          if (statusEl && lastSync) {
            const minAgo = Math.floor((Date.now() - lastSync.getTime()) / 60000);
            let timeStr;
            if (minAgo < 1) timeStr = 'just now';
            else if (minAgo < 60) timeStr = minAgo + 'm ago';
            else timeStr = lastSync.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });

            statusEl.style.color = '#00b894';
            statusEl.textContent = threadCount + ' threads synced ' + timeStr;
            if (dotEl) dotEl.style.background = '#00b894';
          }
          console.log('Gmail data updated:', threadCount, 'threads from Firebase');
        } else {
          const statusEl = document.getElementById('gmailStatus');
          if (statusEl) {
            statusEl.style.color = '#fdcb6e';
            statusEl.textContent = 'No Gmail data. Set up Apps Script sync.';
          }
        }
      });
    }

