    // Initialize
    function init() {
      console.log('CRM v23 init - loading leads...');
      loadLeads();
      console.log('Loaded', leads.length, 'leads');
      loadMeetings();
      console.log('Loaded', meetings.length, 'meetings');
      loadTasks();
      console.log('Loaded', tasks.length, 'tasks');
      refreshInboxDates(); // Recompute daysSince and auto-escalate stale statuses on load
      setupEventListeners();
      populateLeadLinker();
      loadViewPreference();

      // Close detail panel on escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeDetailPanel();
      });

      // Close detail panel on outside click
      document.getElementById('detailPanel').addEventListener('click', (e) => {
        if (e.target.id === 'detailPanel') closeDetailPanel();
      });

      document.getElementById('detailPanelClose').addEventListener('click', closeDetailPanel);

      // Set default to dashboard if no preference saved
      if (!__memStore.getItem('bd_leads_section')) {
        currentSection = 'dashboard';
      }

      // Update inbox badge with overdue count
      const overdueCount = INBOX_EMAILS.filter(e => e.status === 'overdue').length;
      const badge = document.getElementById('inboxBadge');
      if (overdueCount > 0) {
        badge.textContent = overdueCount;
        badge.style.display = 'inline';
      } else {
        badge.style.display = 'none';
      }

      // Update leads badge with total lead count
      const totalLeads = leads.length;
      const leadsBadge = document.getElementById('leadsBadge');
      if (totalLeads > 0) {
        leadsBadge.textContent = totalLeads;
        leadsBadge.style.display = 'inline';
      } else {
        leadsBadge.style.display = 'none';
      }

      // Update tasks badge with overdue count
      const overdueTasksCount = tasks.filter(t => t.status !== 'done' && t.dueDate && t.dueDate < getTodayDate()).length;
      const tasksBadge = document.getElementById('tasksBadge');
      if (overdueTasksCount > 0) {
        tasksBadge.textContent = overdueTasksCount;
        tasksBadge.style.display = 'inline';
      } else {
        tasksBadge.style.display = 'none';
      }

      // Auto-task generation removed at user request — tasks are manual-entry only.

      // Render the active section
      switchSection(currentSection);
      console.log('CRM v23 render complete');
    }

    // Load from Firebase (with __memStore fallback)
    function loadLeads() {
      leads = defaultLeads();
      db.ref('leads').once('value').then(snapshot => {
        const savedLeads = snapshot.val();
        if (savedLeads && Array.isArray(savedLeads)) {
          mergeLeads(savedLeads);
        } else {
          // Fallback: check __memStore for migration
          const stored = __memStore.getItem(STORAGE_KEY);
          if (stored) {
            mergeLeads(JSON.parse(stored));
          }
        }
        saveleads();
        renderAll();
      }).catch(() => {
        // Offline fallback
        const stored = __memStore.getItem(STORAGE_KEY);
        if (stored) mergeLeads(JSON.parse(stored));
        saveleads();
        renderAll();
      });

      // Real-time sync: listen for changes from other users
      db.ref('leads').on('value', snapshot => {
        const savedLeads = snapshot.val();
        if (savedLeads && Array.isArray(savedLeads)) {
          leads = defaultLeads();
          mergeLeads(savedLeads);
          renderAll();
        }
      });
    }

    function mergeLeads(savedLeads) {
      const defaultMap = {};
      leads.forEach(d => { defaultMap[d.id] = d; });
      const validStages = Object.keys(STAGE_LABELS);
      savedLeads.forEach(saved => {
        if (saved.stage === 'won') saved.stage = 'client';
        if (saved.stage === 'lost') saved.stage = 'onhold';
        if (saved.stage === 'meeting') saved.stage = 'meeting_scheduled';
        if (saved.stage === 'proposal') saved.stage = 'report_sent';
        if (saved.stage === 'negotiation') saved.stage = 'contract_sent';
        if (defaultMap[saved.id]) {
          const def = defaultMap[saved.id];
          def.stage = validStages.includes(saved.stage) ? saved.stage : def.stage;
          def.followUp = saved.followUp;
          def.context = saved.context;
        } else {
          if (!validStages.includes(saved.stage)) saved.stage = 'lead';
          leads.push(saved);
        }
      });
    }

    // Save to Firebase + __memStore backup
    function saveleads() {
      __memStore.setItem(STORAGE_KEY, JSON.stringify(leads));
      db.ref('leads').set(leads).catch(err => console.warn('Firebase save error:', err));
    }

