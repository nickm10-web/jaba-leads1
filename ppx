    var topTabs = document.querySelectorAll('.top-tab');
    topTabs.forEach(function(tab) {
      var badgeEl = tab.querySelector('[class*="badge"]');
      if (badgeEl) {
        var count = badgeEl.textContent.trim();
        var sectionId = tab.getAttribute('onclick');
