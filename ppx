    function getFilteredTasks() {
      const today = getTodayDate();
      let filtered = tasks;

      if (currentTaskFilter === 'today') {
        filtered = tasks.filter(t => t.dueDate === today);
      } else if (currentTaskFilter === 'week') {
        const we = new Date(); we.setDate(we.getDate() + (7 - we.getDay())); const weekEnd = we.toISOString().split('T')[0];
        filtered = tasks.filter(t => t.dueDate && t.dueDate >= today && t.dueDate <= weekEnd);
      } else if (currentTaskFilter === 'overdue') {
        filtered = tasks.filter(t => t.status !== 'done' && t.dueDate && t.dueDate < today);
      } else if (currentTaskFilter === 'done') {
        filtered = tasks.filter(t => t.status === 'done');
      }
      // 'all' shows everything

      return filtered.sort((a, b) => {
        if (!a.dueDate && !b.dueDate) return 0;
        if (!a.dueDate) return 1;
        if (!b.dueDate) return -1;
        return a.dueDate.localeCompare(b.dueDate);
      });
    }

    function renderTasks() {
      const filtered = getFilteredTasks();
      const taskList = document.getElementById('taskList');
      const emptyState = document.getElementById('taskEmptyState');

      if (filtered.length === 0) {
        taskList.innerHTML = '';
        emptyState.style.display = 'block';
        updateTaskStats();
        return;
      }

      emptyState.style.display = 'none';

      const today = getTodayDate();
      taskList.innerHTML = filtered.map(task => {
        const lead = task.linkedLeadId ? leads.find(l => l.id === task.linkedLeadId) : null;

        let dueDateClass = 'no-date';
        let dueDateText = 'No date';
        if (task.dueDate) {
          if (task.dueDate < today && task.status !== 'done') {
            dueDateClass = 'overdue';
            dueDateText = `${daysAgo(task.dueDate)} days overdue`;
          } else if (task.dueDate === today) {
            dueDateClass = 'today';
            dueDateText = 'Due Today';
          } else if (task.dueDate > today) {
            dueDateClass = 'future';
            dueDateText = `Due ${daysUntil(task.dueDate)} days`;
          }
        }

        return `
          <div class="task-card ${task.status === 'done' ? 'done' : ''}">
            <div class="task-checkbox" onclick="toggleTaskDone(${task.id})" style="cursor:pointer;">
              ${task.status === 'done' ? '✓' : ''}
            </div>
            <div class="task-content" style="flex:1;">
              <div class="task-title">${task.title}</div>
              <div class="task-meta">
                <span class="task-due-date ${dueDateClass}">${dueDateText}</span>
                <span class="task-priority" style="background:${task.priority === 'high' ? '#ff6b6b' : task.priority === 'medium' ? '#fdcb6e' : '#00b894'};"></span>
                ${lead ? `<span class="task-lead-pill ${lead.bucket}">${lead.company}</span>` : ''}
              </div>
              ${task.notes ? `<div class="task-notes-preview">${task.notes}</div>` : ''}
            </div>
            <div class="task-actions">
              <button class="task-action-btn" onclick="editTask(${task.id})">Edit</button>
              <button class="task-action-btn" onclick="deleteTask(${task.id})">Delete</button>
            </div>
          </div>
        `;
      }).join('');

      updateTaskStats();
    }

