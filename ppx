    function initWeekStart() {
      const today = new Date();
      currentWeekStart = getMonday(today);
    }

    window.prevWeek = function() {
      currentWeekStart.setDate(currentWeekStart.getDate() - 7);
      renderMeetings();
    };

    window.nextWeek = function() {
      currentWeekStart.setDate(currentWeekStart.getDate() + 7);
      renderMeetings();
    };

    function renderMeetings() {
      if (!currentWeekStart) initWeekStart();

      const weekEnd = new Date(currentWeekStart);
      weekEnd.setDate(weekEnd.getDate() + 4);

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      // Update week range
      const formatDate = (d) => {
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        return `${months[d.getMonth()]} ${d.getDate()}`;
      };
      document.getElementById('weekRange').textContent = `${formatDate(currentWeekStart)} — ${formatDate(weekEnd)}`;

      // Build week view
      const weekView = document.getElementById('weekView');
      weekView.innerHTML = '';

      const dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'];
      for (let i = 0; i < 5; i++) {
        const dayDate = new Date(currentWeekStart);
        dayDate.setDate(dayDate.getDate() + i);
        const dayDateStr = dayDate.toISOString().split('T')[0];
        const isToday = dayDate.getTime() === today.getTime();

        const dayMeetings = meetings.filter(m => m.date === dayDateStr).sort((a, b) => {
          if (!a.time && !b.time) return 0;
          if (!a.time) return 1;
          if (!b.time) return -1;
          return a.time.localeCompare(b.time);
        });

        const dayCol = document.createElement('div');
        dayCol.className = `day-column ${isToday ? 'today' : ''}`;

        const dayHeader = document.createElement('div');
        dayHeader.className = 'day-header';
        dayHeader.innerHTML = `
          <div class="day-name">${dayNames[i]}</div>
          <div class="day-date ${isToday ? 'today' : ''}">${formatDate(dayDate)}</div>
        `;
        dayCol.appendChild(dayHeader);

        const meetingsList = document.createElement('div');
        meetingsList.className = 'meetings-list';
        meetingsList.innerHTML = dayMeetings.map(m => {
          const checklist = m.prepChecklist || m.prep || [];
          const checkedCount = checklist.filter(c => c.done).length;
          const totalCount = checklist.length;
          const prepStatus = m.prepStatus || (totalCount === 0 ? 'ready' : 'not_started');
          const statusDot = prepStatus === 'ready' ? '✓' : prepStatus === 'in_progress' ? '◐' : '◯';
          const statusClass = prepStatus.replace('_', '-');

          return `
            <div class="meeting-card" onclick="openMeetingDetail(${m.id})">
              <div class="meeting-card-header">
                <div class="meeting-card-title">
                  <div class="meeting-card-company">${m.company}</div>
                  ${m.time ? `<div class="meeting-card-time">${m.time}</div>` : ''}
                </div>
                <span class="meeting-card-badge meeting-badge-${m.type}">${getMeetingTypeLabel(m.type)}</span>
              </div>
              <div class="meeting-card-meta">
                <span class="meeting-prep-status ${statusClass}"></span>
                <span class="meeting-prep-progress">${checkedCount}/${totalCount} ready</span>
              </div>
            </div>
          `;
        }).join('');

        dayCol.appendChild(meetingsList);

        const addBtn = document.createElement('button');
        addBtn.className = 'add-meeting-btn';
        addBtn.textContent = '+ Add Meeting';
        addBtn.onclick = () => showQuickAddForm(dayDateStr);
        dayCol.appendChild(addBtn);

        weekView.appendChild(dayCol);
      }

      // Render stats
      const thisWeekMeetings = meetings.filter(m => {
        const mDate = new Date(m.date);
        return mDate >= currentWeekStart && mDate <= weekEnd;
      });

      const ready = thisWeekMeetings.filter(m => m.prepStatus === 'ready').length;
      const needsPrep = thisWeekMeetings.filter(m => m.prepStatus !== 'ready' && new Date(m.date) >= today).length;
      const completed = meetings.filter(m => m.outcome && new Date(m.date) < today).length;

      const statsHtml = `
        <div class="meetings-stat-card">
          <div class="meetings-stat-value">${thisWeekMeetings.length}</div>
          <div class="meetings-stat-label">This Week's Meetings</div>
        </div>
        <div class="meetings-stat-card stat-ready">
          <div class="meetings-stat-value">${ready}</div>
          <div class="meetings-stat-label">Ready to Go</div>
        </div>
        <div class="meetings-stat-card stat-needs-prep">
          <div class="meetings-stat-value">${needsPrep}</div>
          <div class="meetings-stat-label">Needs Prep</div>
        </div>
        <div class="meetings-stat-card stat-completed">
          <div class="meetings-stat-value">${completed}</div>
          <div class="meetings-stat-label">Completed</div>
        </div>
      `;
      document.getElementById('meetingsStatsRow').innerHTML = statsHtml;

      // Update badge
      document.getElementById('meetingsBadge').textContent = thisWeekMeetings.length;
    }

