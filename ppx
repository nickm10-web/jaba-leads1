    // Get filtered and sorted leads
    function getDisplayLeads() {
      let filtered = leads;

      // Filter by bucket
      if (currentFilter !== 'all') {
        filtered = filtered.filter(lead => lead.bucket === currentFilter);
      }

      // Filter by search
      if (searchQuery) {
        filtered = filtered.filter(lead =>
          lead.company.toLowerCase().includes(searchQuery) ||
          lead.contacts.some(c => c.toLowerCase().includes(searchQuery)) ||
          lead.context.toLowerCase().includes(searchQuery)
        );
      }

      // Filter by overdue if flagged
      if (window.showOnlyOverdue) {
        const today = getTodayDate();
        filtered = filtered.filter(lead => lead.followUp && lead.followUp < today);
      }

      // Sort
      if (sortColumn) {
        filtered.sort((a, b) => {
          let aVal = a[sortColumn];
          let bVal = b[sortColumn];

          if (sortColumn === 'followUp') {
            aVal = aVal ? new Date(aVal).getTime() : Infinity;
            bVal = bVal ? new Date(bVal).getTime() : Infinity;
          } else if (typeof aVal === 'string') {
            aVal = aVal.toLowerCase();
            bVal = bVal.toLowerCase();
          }

          if (aVal < bVal) return sortDirection === 'asc' ? -1 : 1;
          if (aVal > bVal) return sortDirection === 'asc' ? 1 : -1;
          return 0;
        });
      }

      return filtered;
    }

