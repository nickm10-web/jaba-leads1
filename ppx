    window.openThreadView = function(threadId) {
      const thread = gmailThreadCache[threadId];
      if (!thread || !thread.messages) return;
      activeThreadId = threadId;
      const msgs = [...thread.messages].sort((a, b) => a.timestamp - b.timestamp);
      const panel = document.getElementById('threadPanel');

      // Render immediately with snippets
      panel.innerHTML = renderThreadPanelHtml(thread, msgs);
      panel.style.display = 'block';

      // If we have a Gmail token, fetch full message bodies in background
      if (gmailAccessToken) {
        (async function() {
          try {
            const fullMsgs = await Promise.all(msgs.map(msg =>
              fetch(`https://gmail.googleapis.com/gmail/v1/users/me/messages/${msg.id}?format=full`, {
                headers: { 'Authorization': 'Bearer ' + gmailAccessToken }
              }).then(r => r.ok ? r.json() : null).catch(() => null)
            ));

            // Extract bodies and update msgs
            let updated = false;
            fullMsgs.forEach((fullMsg, i) => {
              if (fullMsg && fullMsg.payload) {
                const body = extractBodyFromParts(fullMsg.payload);
                if (body) {
                  msgs[i].fullBody = body;
                  updated = true;
                }
              }
            });

            // Re-render panel with full bodies if still viewing this thread
