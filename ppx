    // Drag and drop handlers
    let draggedCard = null;
    let draggedCardStage = null;

    function handleDragStart(e) {
      draggedCard = e.target.closest('.pipeline-card');
      draggedCardStage = draggedCard.closest('.pipeline-column').dataset.stage;
      draggedCard.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    }

    function handleDragEnd(e) {
      draggedCard.classList.remove('dragging');
      document.querySelectorAll('.pipeline-column').forEach(col => {
        col.classList.remove('drag-over');
      });
      draggedCard = null;
      draggedCardStage = null;
    }

    function handleDragOver(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      const column = e.target.closest('.pipeline-column');
      if (column && draggedCard) {
        column.classList.add('drag-over');
      }
    }

    function handleDragLeave(e) {
      const column = e.target.closest('.pipeline-column');
      if (column) {
        column.classList.remove('drag-over');
      }
    }

    function handleDrop(e) {
      e.preventDefault();
      const targetColumn = e.target.closest('.pipeline-column');

      if (draggedCard && targetColumn) {
        const newStage = targetColumn.dataset.stage;
        const leadId = parseInt(draggedCard.dataset.leadId);
        const lead = leads.find(l => l.id === leadId);

        if (lead && lead.stage !== newStage) {
          lead.stage = newStage;
          saveleads();
          renderPipeline();
        }
      }

      targetColumn.classList.remove('drag-over');
    }

