    function onGmailToken(response) {
      if (response.access_token) {
        gmailAccessToken = response.access_token;
        const expiresIn = (response.expires_in || 3600) * 1000;
        setGmailConnectedUI();
        document.getElementById('gmailStatus').style.display = 'inline';
        document.getElementById('gmailStatus').style.color = '#fdcb6e';
        document.getElementById('gmailStatus').textContent = 'Syncing...';

        // Save token
        __memStore.setItem('gmail_access_token', response.access_token);
        __memStore.setItem('gmail_token_expiry', Date.now() + expiresIn);

        // Schedule silent refresh 5 minutes before expiry
        if (gmailRefreshTimer) clearTimeout(gmailRefreshTimer);
        const refreshIn = Math.max(expiresIn - (5 * 60 * 1000), 60000); // at least 1 min
        gmailRefreshTimer = setTimeout(silentRefreshGmail, refreshIn);
        console.log('Gmail token expires in', Math.round(expiresIn/60000), 'min. Refresh scheduled in', Math.round(refreshIn/60000), 'min.');

        fetchGmailEmails();
        // Sync emails every 5 minutes
        if (gmailSyncInterval) clearInterval(gmailSyncInterval);
        gmailSyncInterval = setInterval(fetchGmailEmails, 5 * 60 * 1000);
      }
    }

    function silentRefreshGmail() {
      console.log('Silently refreshing Gmail token...');
      document.getElementById('gmailStatus').style.display = 'inline';
      document.getElementById('gmailStatus').style.color = '#fdcb6e';
      document.getElementById('gmailStatus').textContent = 'Refreshing...';
      if (gmailTokenClient) {
        // prompt: '' means no popup if user already granted consent
        gmailTokenClient.requestAccessToken({ prompt: '' });
      }
    }

    function initGmailAuth() {
      if (typeof google === 'undefined' || !google.accounts) {
        setTimeout(initGmailAuth, 500);
        return;
      }
      gmailTokenClient = google.accounts.oauth2.initTokenClient({
        client_id: GMAIL_CLIENT_ID,
        scope: GMAIL_SCOPES,
        callback: onGmailToken,
        error_callback: (err) => {
          console.error('Gmail auth error:', err);
          // If silent refresh fails, show reconnect
          if (gmailAccessToken) {
            // Had a token before, try to keep using it
            document.getElementById('gmailStatus').style.display = 'inline';
            document.getElementById('gmailStatus').style.color = '#fdcb6e';
            document.getElementById('gmailStatus').textContent = 'Refresh pending...';
            // Retry in 2 minutes
            if (gmailRefreshTimer) clearTimeout(gmailRefreshTimer);
            gmailRefreshTimer = setTimeout(silentRefreshGmail, 2 * 60 * 1000);
          } else {
            document.getElementById('gmailStatus').style.display = 'inline';
            document.getElementById('gmailStatus').style.color = '#ff6b6b';
            document.getElementById('gmailStatus').textContent = 'Auth failed';
          }
        }
      });

      // Check for saved token
      const savedToken = __memStore.getItem('gmail_access_token');
      const expiry = __memStore.getItem('gmail_token_expiry');
      if (savedToken && expiry) {
        const timeLeft = parseInt(expiry) - Date.now();
        if (timeLeft > 60000) {
          // Token still valid (more than 1 min left)
          gmailAccessToken = savedToken;
          setGmailConnectedUI();
          fetchGmailEmails();
          if (gmailSyncInterval) clearInterval(gmailSyncInterval);
          gmailSyncInterval = setInterval(fetchGmailEmails, 5 * 60 * 1000);
          // Schedule refresh before expiry
          const refreshIn = Math.max(timeLeft - (5 * 60 * 1000), 30000);
          gmailRefreshTimer = setTimeout(silentRefreshGmail, refreshIn);
          console.log('Gmail token restored. Refresh in', Math.round(refreshIn/60000), 'min.');
        } else {
          // Token expired or about to, try silent refresh
          console.log('Saved Gmail token expired, attempting silent refresh...');
          setGmailConnectedUI();
          setTimeout(silentRefreshGmail, 1000);
        }
      }
    }

