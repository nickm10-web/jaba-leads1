    function loadMeetings() {
      meetings = defaultMeetings();
      db.ref('meetings').once('value').then(snapshot => {
        const saved = snapshot.val();
        if (saved && Array.isArray(saved)) {
          mergeMeetings(saved);
        } else {
          const stored = __memStore.getItem(MEETINGS_STORAGE_KEY);
          if (stored) mergeMeetings(JSON.parse(stored));
        }
        saveMeetings();
        renderAll();
      }).catch(() => {
        const stored = __memStore.getItem(MEETINGS_STORAGE_KEY);
        if (stored) mergeMeetings(JSON.parse(stored));
        saveMeetings();
      });

      db.ref('meetings').on('value', snapshot => {
        const saved = snapshot.val();
        if (saved && Array.isArray(saved)) {
          meetings = defaultMeetings();
          mergeMeetings(saved);
          renderAll();
        }
      });

      // Also listen for calendar_meetings from Apps Script sync
      db.ref('calendar_meetings').on('value', snapshot => {
        const data = snapshot.val();
        if (data && data.meetings && Array.isArray(data.meetings)) {
          // Filter: include meetings with JABA/Jordon in title, attendees, or organizer
          // Also include any meeting where jordon@jaba.ai is an attendee
          const calMeetings = data.meetings
            .filter(cm => {
              if (!cm.title) return false;
              const title = cm.title.toLowerCase();
              const desc = (cm.description || '').toLowerCase();
              const attendeeStr = (cm.attendees || []).map(a => (a.email || '') + ' ' + (a.name || '')).join(' ').toLowerCase();
              // Include if JABA or Jordon appears anywhere
              if (/jaba|jordon/i.test(title + ' ' + desc + ' ' + attendeeStr)) return true;
              // Include if jordon@jaba.ai is in attendees
              if (attendeeStr.includes('jordon@jaba.ai')) return true;
              // Include "x" pattern meetings (Company x Company)
              if (/\bx\b/i.test(title)) return true;
              // Include meetings with known lead companies
              const leadMatch = leads.some(l => title.includes(l.company.toLowerCase()));
              if (leadMatch) return true;
              return false;
            })
            .map(cm => {
            const start = new Date(cm.startTime);
            const end = new Date(cm.endTime);
            if (isNaN(start.getTime())) return null;
            const timeStr = start.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
            const endTimeStr = end.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
            const exists = meetings.find(m => (m.title === cm.title && m.date === cm.date) || (m.id === 'gcal_' + (cm.id || '').substring(0, 8)));
            if (exists) return null;

            // Extract company/contact from title
            let company = cm.company || '', contact = cm.contact || '';
            const titleParts = cm.title.split(/\s*x\s*/i);
            if (titleParts.length === 2) {
              const left = titleParts[0].trim();
              const right = titleParts[1].trim();
              if (/jaba/i.test(right)) { company = company || left; contact = contact || left; }
              else if (/jaba/i.test(left)) { company = company || right; contact = contact || right; }
              else if (/jordon/i.test(left)) { contact = contact || right; company = company || right; }
              else if (/jordon/i.test(right)) { contact = contact || left; company = company || left; }
              else { company = company || left; contact = contact || right; }
            }
            // Try to match to a CRM lead by company name
            if (!company) {
              const titleLower = cm.title.toLowerCase();
              const matchedLead = leads.find(l => titleLower.includes(l.company.toLowerCase()));
              if (matchedLead) company = matchedLead.company;
            }
            // Fall back to first attendee who isn't jordon
            if (!contact && cm.attendees) {
              const other = cm.attendees.find(a => a.email && !a.email.includes('jordon') && !a.email.includes('jaba'));
              if (other) contact = other.name || other.email;
            }

            return {
              id: 'gcal_' + (cm.id || '').substring(0, 8),
              title: cm.title,
              company: company || contact || cm.title.split(/\s*[@x]\s*/i)[0].trim(),
              contact: contact || '',
              date: cm.date,
              time: timeStr,
              endTime: endTimeStr,
              location: cm.location || '',
              type: 'call',
              status: start < new Date() ? 'completed' : 'confirmed',
              notes: cm.description || '',
              prep: [],
              attendees: (cm.attendees || []).map(a => a.name || a.email),
              fromCalendar: true
            };
          }).filter(Boolean);

          if (calMeetings.length > 0) {
            calMeetings.forEach(cm => {
              if (!meetings.find(m => (m.title === cm.title && m.date === cm.date) || m.id === cm.id)) {
                meetings.push(cm);
              }
            });
            if (currentSection === 'meetings') renderMeetings();
            renderInbox(); // Update meeting count in pipeline
          }
          console.log('Calendar: loaded', calMeetings.length, 'new meetings from Google Calendar');
        }
      });
    }

    function mergeMeetings(savedMeetings) {
      const defaultMap = {};
      meetings.forEach(m => { defaultMap[m.id] = m; });
      savedMeetings.forEach(saved => {
        if (defaultMap[saved.id]) {
          const def = defaultMap[saved.id];
          def.prepStatus = saved.prepStatus;
          def.prepChecklist = saved.prepChecklist || def.prepChecklist;
          def.notes = saved.notes;
          def.meetingNotes = saved.meetingNotes;
          def.outcome = saved.outcome;
          def.time = saved.time;
          def.attendees = saved.attendees || def.attendees;
        } else {
          meetings.push(saved);
        }
      });
    }

