    window.sendReply = async function() {
      if (!gmailAccessToken) {
        // Need to connect first
        if (gmailTokenClient) {
          gmailTokenClient.requestAccessToken({ prompt: 'consent' });
        }
        document.getElementById('sendStatus').textContent = 'Connect Gmail first...';
        document.getElementById('sendStatus').style.color = '#fdcb6e';
        return;
      }

      const thread = gmailThreadCache[activeThreadId];
      if (!thread) return;
      const body = document.getElementById('composeBody').value.trim();
      if (!body) return;

      const statusEl = document.getElementById('sendStatus');
      statusEl.textContent = 'Sending...';
      statusEl.style.color = '#fdcb6e';

      const msgs = [...thread.messages].sort((a, b) => b.timestamp - a.timestamp);
      const subject = msgs[0]?.subject || '(no subject)';
      const replySubject = subject.startsWith('Re:') ? subject : 'Re: ' + subject;
      const toEmail = thread.email;

      // Build RFC 2822 email
      const emailLines = [
        'To: ' + toEmail,
        'From: Jordon Rooney <jordon@jaba.ai>',
        'Subject: ' + replySubject,
        'Content-Type: text/plain; charset=UTF-8',
        '',
        body
      ];
      const rawEmail = emailLines.join('\r\n');
      const encodedEmail = btoa(unescape(encodeURIComponent(rawEmail)))
        .replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');

      try {
        const res = await fetch('https://gmail.googleapis.com/gmail/v1/users/me/messages/send', {
          method: 'POST',
          headers: {
            'Authorization': 'Bearer ' + gmailAccessToken,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            raw: encodedEmail,
            threadId: activeThreadId
          })
        });

        if (res.status === 401) {
          statusEl.textContent = 'Token expired. Reconnecting...';
          silentRefreshGmail();
          return;
        }

        if (res.ok) {
          statusEl.textContent = 'Sent!';
          statusEl.style.color = '#00b894';
          document.getElementById('composeBody').value = '';

          // Update thread cache: add sent message so it moves to "Waiting" pipeline
          const sentMsg = await res.json();
          const now = Date.now();
          if (thread.messages) {
            thread.messages.push({
              id: sentMsg.id || '',
              from: 'Jordon Rooney <jordon@jaba.ai>',
              to: toEmail,
              subject: replySubject,
              timestamp: now,
              isSent: true,
              snippet: body.substring(0, 100)
            });
          }

          // Update INBOX_EMAILS entry: we sent last, so status = pending (waiting)
          const inboxEntry = INBOX_EMAILS.find(e => e && e.email && e.email.toLowerCase() === thread.email.toLowerCase());
          if (inboxEntry) {
            inboxEntry.status = 'pending';
            inboxEntry.daysSince = 0;
            inboxEntry.sentDate = getTodayDate();
            inboxEntry.note = 'Sent, waiting for reply.';
            delete inboxEntry.pipelineOverride;
            delete inboxEntry.dismissed;
            saveInboxOverrides();
          }

          // Re-render inbox views to reflect the move
          renderInbox();
          if (currentInboxView === 'gmail') renderGmailInbox();

          setTimeout(() => {
            statusEl.textContent = '';
          }, 3000);
        } else {
          const err = await res.json();
          statusEl.textContent = 'Error: ' + (err.error?.message || 'Failed to send');
          statusEl.style.color = '#ff6b6b';
        }
      } catch (err) {
        statusEl.textContent = 'Error: ' + err.message;
        statusEl.style.color = '#ff6b6b';
      }
    };

