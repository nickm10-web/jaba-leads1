      color: var(--text-primary);
      font-size: 24px;
      cursor: pointer;
      padding: 0;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-close:hover {
      color: var(--text-secondary);
    }

    .modal-body {
      padding: 24px;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--text-primary);
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 8px 12px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-primary);
      font-size: 13px;
      font-family: inherit;
      transition: all 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--color-info);
      box-shadow: 0 0 0 3px rgba(9, 116, 217, 0.1);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 80px;
    }

    .form-group select {
      cursor: pointer;
    }

    .modal-footer {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
      padding: 24px;
      border-top: 1px solid var(--border);
    }

    .modal-footer .btn {
      min-width: 100px;
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 48px 24px;
      color: var(--text-secondary);
    }

    .empty-state-icon {
      font-size: 48px;
      margin-bottom: 16px;
      opacity: 0.5;
    }

    .empty-state p {
      margin-bottom: 24px;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .header {
        flex-direction: column;
        align-items: flex-start;
      }

      .header-actions {
        width: 100%;
      }

      .header-actions .btn {
        flex: 1;
        justify-content: center;
      }

      .filter-bar {
        flex-direction: column;
      }

      .filter-btn {
        width: 100%;
      }

      .stats-row {
        grid-template-columns: 1fr 1fr;
      }

      .table-wrapper {
        overflow-x: auto;
      }

      table {
        min-width: 800px;
      }

      .company-cell {
        min-width: 150px;
      }

      .modal-content {
        width: 95%;
        max-height: 95vh;
      }

      .pipeline-view {
        flex-direction: column;
      }

      .pipeline-column {
        min-width: unset;
        width: 100%;
      }

      .task-quick-add {
        grid-template-columns: 1fr;
      }

      .view-toggle {
        width: 100%;
        justify-content: stretch;
      }

      .view-toggle-btn {
        flex: 1;
      }

      .container {
        padding: 12px;
      }

      .detail-panel {
        width: 100%;
      }
    }

    @media (max-width: 480px) {
      .stats-row {
        grid-template-columns: 1fr;
      }

      .header h1 {
        font-size: 18px;
      }

      .filter-bar {
        gap: 4px;
      }

      .filter-btn {
        font-size: 12px;
        padding: 6px 8px;
      }

      .actions-cell {
        flex-direction: column;
        gap: 4px;
      }

      .btn-action {
        font-size: 11px;
        padding: 4px 8px;
      }
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: var(--bg-primary);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: var(--text-secondary);
    }

    /* Utility */
    .text-muted {
      color: var(--text-secondary);
      font-size: 12px;
    }

    /* Inbox View */
    .inbox-header {
      margin-bottom: 20px;
    }
    .inbox-stats {
      display: flex;
      gap: 16px;
      margin-bottom: 24px;
    }
    .inbox-stat {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 24px;
      flex: 1;
      text-align: center;
    }
    .inbox-stat-danger { border-left: 3px solid #ff6b6b; }
    .inbox-stat-warning { border-left: 3px solid #fdcb6e; }
    .inbox-stat-success { border-left: 3px solid #00b894; }
    .inbox-stat-num {
      font-size: 28px;
      font-weight: 700;
      display: block;
      margin-bottom: 4px;
    }
    .inbox-stat-danger .inbox-stat-num { color: #ff6b6b; }
    .inbox-stat-warning .inbox-stat-num { color: #fdcb6e; }
    .inbox-stat-success .inbox-stat-num { color: #00b894; }
    .inbox-stat-label {
      font-size: 13px;
      color: var(--text-secondary);
    }
    .inbox-section {
      margin-bottom: 32px;
    }
    .inbox-section-title {
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }
    .inbox-section-title.danger { color: #ff6b6b; }
    .inbox-section-title.warning { color: #fdcb6e; }
    .inbox-section-title.success { color: #00b894; }
    .inbox-item {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: all 0.15s;
      cursor: pointer;
    }
    .inbox-item:hover {
      border-color: var(--text-secondary);
      background: var(--bg-tertiary);
    }
    .inbox-item-logo {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      overflow: hidden;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-tertiary);
    }
    .inbox-item-logo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .inbox-item-initials {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 14px;
    }
    .inbox-item-content {
      flex: 1;
      min-width: 0;
    }
    .inbox-item-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 4px;
    }
    .inbox-item-company {
      font-weight: 600;
      font-size: 14px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .inbox-item-contact {
      font-size: 12px;
      color: var(--text-secondary);
    }
    .inbox-item-subject {
      font-size: 13px;
      color: var(--text-secondary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .inbox-item-meta {
      text-align: right;
      flex-shrink: 0;
    }
    .inbox-item-days {
      font-size: 13px;
      font-weight: 600;
    }
    .inbox-item-days.overdue { color: #ff6b6b; }
    .inbox-item-days.pending { color: #fdcb6e; }
    .inbox-item-days.replied { color: #00b894; }
    .inbox-item-date {
      font-size: 11px;
      color: var(--text-secondary);
    }
    .inbox-item-stage {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 4px;
      background: var(--bg-primary);
      color: var(--text-secondary);
      margin-top: 4px;
      display: inline-block;
    }

    /* Inbox View Toggle */
    .inbox-view-toggle {
      display: flex;
      gap: 4px;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 4px;
      margin-bottom: 20px;
    }
    .inbox-view-btn {
      padding: 8px 20px;
      border: none;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      background: transparent;
      color: var(--text-secondary);
      transition: all 0.2s;
      font-family: 'DM Sans', sans-serif;
    }
    .inbox-view-btn.active {
      background: var(--accent);
      color: #000;
    }

    /* Kanban Pipeline */
    .inbox-kanban {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      height: calc(100vh - 240px);
      min-height: 400px;
    }
    .kanban-col {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    .kanban-col-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--border);
      flex-shrink: 0;
    }
    .kanban-col-title {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-family: 'Saira Extra Condensed', sans-serif;
    }
    .kanban-col-count {
      font-size: 12px;
      font-weight: 700;
      background: var(--bg-primary);
      padding: 2px 8px;
      border-radius: 10px;
      color: var(--text-secondary);
    }
    .kanban-col-body {
      flex: 1;
      overflow-y: auto;
      min-height: 0;
    }
    .kanban-col-body::-webkit-scrollbar { width: 4px; }
    .kanban-col-body::-webkit-scrollbar-track { background: transparent; }
    .kanban-col-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    .kanban-col.needs-reply .kanban-col-header { border-bottom-color: #ff6b6b; }
    .kanban-col.needs-reply .kanban-col-title { color: #ff6b6b; }
    .kanban-col.waiting .kanban-col-header { border-bottom-color: #fdcb6e; }
    .kanban-col.waiting .kanban-col-title { color: #fdcb6e; }
    .kanban-col.active-conv .kanban-col-header { border-bottom-color: #00b894; }
    .kanban-col.active-conv .kanban-col-title { color: #00b894; }
    .kanban-col.meeting-set .kanban-col-header { border-bottom-color: #74b9ff; }
    .kanban-col.meeting-set .kanban-col-title { color: #74b9ff; }

    .kanban-card {
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px;
      margin-bottom: 6px;
      cursor: grab;
      transition: all 0.15s;
      position: relative;
      user-select: none;
    }
    .kanban-card:hover {
      border-color: var(--text-secondary);
      transform: translateY(-1px);
    }
    .kanban-card.dragging {
      opacity: 0.4;
      cursor: grabbing;
    }
    .kanban-col.drag-over {
      background: var(--bg-tertiary);
      border: 2px dashed var(--accent);
    }
    .kanban-card-dismiss {
      position: absolute;
      top: 4px;
      right: 4px;
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 14px;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.15s;
      padding: 0 4px;
      line-height: 1;
      z-index: 1;
    }
    .kanban-card:hover .kanban-card-dismiss {
      opacity: 0.7;
    }
    .kanban-card-dismiss:hover {
      opacity: 1 !important;
      color: #ff6b6b;
    }
    .kanban-card-name {
      font-weight: 600;
      font-size: 12px;
      margin-bottom: 1px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .kanban-card-company {
      font-size: 10px;
      color: var(--text-secondary);
      margin-bottom: 4px;
    }
    .kanban-card-subject {
      font-size: 10px;
      color: var(--text-secondary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-bottom: 4px;
    }
    .kanban-card-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .kanban-card-days {
      font-size: 10px;
      font-weight: 600;
      padding: 1px 5px;
      border-radius: 4px;
    }
    .kanban-card-days.urgent { background: rgba(255,107,107,0.15); color: #ff6b6b; }
    .kanban-card-days.warn { background: rgba(253,203,110,0.15); color: #fdcb6e; }
    .kanban-card-days.ok { background: rgba(0,184,148,0.15); color: #00b894; }
    .kanban-card-days.info { background: rgba(116,185,255,0.15); color: #74b9ff; }
    .kanban-card-note {
      font-size: 9px;
      color: var(--text-secondary);
      margin-top: 4px;
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Timeline Table */
    .inbox-timeline {
      width: 100%;
      border-collapse: collapse;
    }
    .inbox-timeline th {
      text-align: left;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      padding: 12px 16px;
      border-bottom: 2px solid var(--border);
      font-family: 'Saira Extra Condensed', sans-serif;
      position: sticky;
      top: 0;
      background: var(--bg-primary);
    }
    .inbox-timeline td {
      padding: 10px 16px;
      font-size: 13px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    .inbox-timeline tr {
      transition: background 0.15s;
      cursor: pointer;
    }
    .inbox-timeline tr:hover {
      background: var(--bg-tertiary);
    }
    .timeline-status-pill {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .timeline-status-pill.needs-reply { background: rgba(255,107,107,0.15); color: #ff6b6b; }
    .timeline-status-pill.waiting { background: rgba(253,203,110,0.15); color: #fdcb6e; }
    .timeline-status-pill.active { background: rgba(0,184,148,0.15); color: #00b894; }
    .timeline-status-pill.meeting { background: rgba(116,185,255,0.15); color: #74b9ff; }
    .timeline-days-badge {
      font-weight: 700;
      font-size: 13px;
    }
    .timeline-days-badge.urgent { color: #ff6b6b; }
    .timeline-days-badge.warn { color: #fdcb6e; }
    .timeline-days-badge.ok { color: #00b894; }
    .timeline-note {
      font-size: 11px;
      color: var(--text-secondary);
      max-width: 250px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    @media (max-width: 1100px) {
      .inbox-kanban {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 600px) {
      .inbox-kanban {
        grid-template-columns: 1fr;
      }
    }

    /* Tasks View */
    .task-quick-add {
      display: grid;
      grid-template-columns: 1fr 150px 120px 150px 100px;
      gap: 12px;
      margin-bottom: 24px;
      padding: 16px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      align-items: flex-end;
    }
    .task-quick-add input,
    .task-quick-add select {
      padding: 10px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-primary);
      font-size: 13px;
      font-family: inherit;
    }
    .task-quick-add input:focus,
    .task-quick-add select:focus {
      outline: none;
      border-color: var(--color-info);
      box-shadow: 0 0 0 3px rgba(9, 116, 217, 0.1);
    }
    .task-quick-add input::placeholder {
      color: var(--text-secondary);
    }
    .task-quick-add .btn {
      height: 40px;
    }

    .task-stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }
    .task-stat-card {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      padding: 16px;
      text-align: center;
    }
    .task-stat-num {
      font-family: 'Anton', sans-serif;
      font-size: 28px;
      color: var(--accent);
      display: block;
      margin-bottom: 4px;
    }
    .task-stat-label {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 12px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .task-filter-bar {
      display: flex;
      gap: 8px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }
    .task-filter-btn {
      padding: 6px 12px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-primary);
      border-radius: 6px;
      cursor: pointer;
      font-size: 13px;
      transition: all 0.2s;
    }
    .task-filter-btn:hover {
      background: var(--bg-tertiary);
      border-color: var(--text-secondary);
    }
    .task-filter-btn.active {
      background: var(--color-info);
      border-color: var(--color-info);
      color: #fff;
    }

    .task-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .task-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      transition: all 0.15s;
      cursor: pointer;
      position: relative;
    }
    .task-card:hover {
      border-color: var(--text-secondary);
      background: var(--bg-tertiary);
    }
    .task-card.done {
      opacity: 0.6;
    }
    .task-card.done .task-title {
      text-decoration: line-through;
      color: var(--text-secondary);
    }

    .task-checkbox {
      width: 24px;
      height: 24px;
      min-width: 24px;
      border: 2px solid var(--border);
      border-radius: 6px;
      background: transparent;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 2px;
      transition: all 0.2s;
    }
    .task-checkbox:hover {
      border-color: var(--accent);
      background: rgba(226, 245, 0, 0.1);
    }
    .task-card.done .task-checkbox {
      background: var(--accent);
      border-color: var(--accent);
      color: #000;
      font-weight: 700;
      font-size: 14px;
    }

    .task-content {
      flex: 1;
      min-width: 0;
    }
    .task-title {
      font-weight: 600;
      font-size: 14px;
      color: var(--text-primary);
      margin-bottom: 6px;
      word-break: break-word;
    }
    .task-meta {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }
    .task-due-date {
      font-size: 12px;
      padding: 3px 8px;
      border-radius: 4px;
      white-space: nowrap;
    }
    .task-due-date.overdue {
      background: rgba(255, 107, 107, 0.15);
      color: #ff6b6b;
      font-weight: 600;
    }
    .task-due-date.today {
      background: rgba(253, 203, 110, 0.15);
      color: #fdcb6e;
      font-weight: 600;
    }
    .task-due-date.future {
      background: rgba(139, 148, 158, 0.15);
      color: var(--text-secondary);
    }
    .task-due-date.no-date {
      color: var(--text-secondary);
      font-style: italic;
    }

    .task-priority {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .task-priority.high {
      background: #ff6b6b;
    }
    .task-priority.medium {
      background: #fdcb6e;
    }
    .task-priority.low {
      background: #00b894;
    }

    .task-lead-pill {
      font-size: 11px;
      padding: 3px 8px;
      border-radius: 4px;
      white-space: nowrap;
      color: #000;
      font-weight: 600;
      flex-shrink: 0;
    }
    .task-lead-pill.schools {
      background: var(--color-schools);
    }
    .task-lead-pill.teams {
      background: var(--color-teams);
    }
    .task-lead-pill.athlete {
      background: var(--color-athlete);
    }
    .task-lead-pill.agencies {
      background: var(--color-agencies);
    }
    .task-lead-pill.brands {
      background: var(--color-brands);
    }

    .task-notes-preview {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 6px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .task-actions {
      display: none;
      gap: 6px;
      flex-shrink: 0;
    }
    .task-card:hover .task-actions {
      display: flex;
    }
    .task-action-btn {
      padding: 6px 10px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text-primary);
      cursor: pointer;
      font-size: 12px;
      transition: all 0.2s;
    }
    .task-action-btn:hover {
      background: var(--color-info);
      border-color: var(--color-info);
      color: #fff;
    }

    .task-modal-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    .task-modal-overlay.active {
      display: flex;
    }
    .task-modal-content {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 24px;
      width: 90%;
      max-width: 500px;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
    }
    .task-modal-header {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 16px;
      color: var(--text-primary);
    }
    .task-modal-close {
      position: absolute;
      top: 12px;
      right: 12px;
      background: transparent;
      border: none;
      color: var(--text-secondary);
      cursor: pointer;
      font-size: 24px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .task-modal-close:hover {
      color: var(--text-primary);
    }

    .task-empty-state {
      text-align: center;
      padding: 48px 24px;
      color: var(--text-secondary);
    }
    .task-empty-state-icon {
      font-size: 48px;
      margin-bottom: 16px;
      opacity: 0.5;
    }

    /* Meetings View */
    .meetings-stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .meetings-stat-card {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      padding: 16px;
      text-align: center;
    }

    .meetings-stat-value {
      font-family: 'Anton', sans-serif;
      font-size: 28px;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 4px;
    }

    .meetings-stat-label {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
    }

    .meetings-stat-card.stat-ready .meetings-stat-value {
      color: var(--color-success);
    }

    .meetings-stat-card.stat-needs-prep .meetings-stat-value {
      color: var(--color-danger);
    }

    .meetings-stat-card.stat-completed .meetings-stat-value {
      color: var(--color-info);
    }

    /* Week View */
    .week-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      gap: 16px;
    }

    .week-nav {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .week-nav-btn {
      padding: 6px 12px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-primary);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .week-nav-btn:hover {
      background: var(--bg-secondary);
      border-color: var(--text-secondary);
    }

    .week-range {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 16px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      min-width: 200px;
      text-align: center;
    }

    .week-view {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .day-column {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      padding: 12px;
      min-height: 400px;
      display: flex;
      flex-direction: column;
    }

    .day-column.today {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(226, 245, 0, 0.1);
    }

    .day-header {
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 12px;
    }

    .day-name {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-primary);
    }

    .day-date {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 2px;
    }

    .day-date.today {
      color: var(--accent);
      font-weight: 600;
    }

    .meetings-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      flex: 1;
    }

    .add-meeting-btn {
      margin-top: auto;
      padding: 8px 12px;
      background: var(--bg-tertiary);
      border: 1px dashed var(--border);
      border-radius: 6px;
      color: var(--text-secondary);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .add-meeting-btn:hover {
      background: var(--bg-secondary);
      border-color: var(--text-primary);
      color: var(--text-primary);
    }

    /* Meeting Card */
    .meeting-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .meeting-card:hover {
      border-color: var(--accent);
      box-shadow: 0 4px 12px rgba(226, 245, 0, 0.1);
      background: var(--bg-tertiary);
    }

    .meeting-card-header {
      display: flex;
      gap: 8px;
      align-items: flex-start;
      justify-content: space-between;
    }

    .meeting-card-title {
      flex: 1;
      min-width: 0;
    }

    .meeting-card-company {
      font-weight: 600;
      font-size: 13px;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .meeting-card-time {
      font-size: 11px;
      color: var(--text-secondary);
    }

    .meeting-card-badge {
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .meeting-badge-intro { background: rgba(9, 116, 217, 0.3); color: #0984e3; }
    .meeting-badge-demo { background: rgba(0, 184, 148, 0.3); color: var(--color-success); }
    .meeting-badge-follow_up { background: rgba(253, 203, 110, 0.3); color: var(--color-warning); }
    .meeting-badge-contract { background: rgba(162, 155, 254, 0.3); color: #a29bfe; }
    .meeting-badge-check_in { background: rgba(139, 148, 158, 0.3); color: var(--text-secondary); }
    .meeting-badge-pitch { background: rgba(241, 90, 36, 0.3); color: #f15a24; }

    .meeting-card-meta {
      display: flex;
      gap: 6px;
      align-items: center;
      font-size: 10px;
      color: var(--text-secondary);
      flex-wrap: wrap;
    }

    .meeting-prep-status {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .meeting-prep-status.not-started { background: var(--color-danger); }
    .meeting-prep-status.in-progress { background: var(--color-warning); }
    .meeting-prep-status.ready { background: var(--color-success); }

    .meeting-prep-progress {
      font-size: 10px;
      color: var(--text-secondary);
    }

    /* Meeting Detail Modal */
    .meeting-detail-modal {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      padding: 24px;
      max-width: 700px;
      max-height: 90vh;
      overflow-y: auto;
    }

    .meeting-detail-header {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }

    .meeting-detail-logo {
      width: 64px;
      height: 64px;
      border-radius: 8px;
      background: var(--bg-tertiary);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }

    .meeting-detail-logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .meeting-detail-info {
      flex: 1;
    }

    .meeting-detail-company {
      font-size: 20px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 8px;
      font-family: 'Saira Extra Condensed', sans-serif;
      text-transform: uppercase;
    }

    .meeting-detail-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 8px;
    }

    .meeting-detail-meta-item {
      display: flex;
      gap: 6px;
      align-items: center;
      font-size: 13px;
      color: var(--text-secondary);
    }

    .meeting-detail-section {
      margin-bottom: 24px;
    }

    .meeting-detail-section-title {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      margin-bottom: 12px;
    }

    .meeting-checklist {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .meeting-checklist-item {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .meeting-checklist-item input[type="checkbox"] {
      width: 16px;
      height: 16px;
      cursor: pointer;
      flex-shrink: 0;
    }

    .meeting-checklist-item label {
      flex: 1;
      cursor: pointer;
      font-size: 13px;
      color: var(--text-primary);
    }

    .meeting-checklist-item input[type="checkbox"]:checked + label {
      color: var(--text-secondary);
      text-decoration: line-through;
    }

    .meeting-textarea {
      width: 100%;
      padding: 10px;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-primary);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      min-height: 80px;
      resize: vertical;
    }

    .meeting-textarea:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(226, 245, 0, 0.1);
    }

    .meeting-detail-actions {
      display: flex;
      gap: 12px;
      margin-top: 24px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
    }

    .meeting-btn-save {
      flex: 1;
      padding: 10px 16px;
      background: var(--color-info);
      border: none;
      border-radius: 6px;
      color: #fff;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .meeting-btn-save:hover {
      background: #0970c4;
    }

    .meeting-btn-delete {
      padding: 10px 16px;
      background: transparent;
      border: 1px solid var(--color-danger);
      border-radius: 6px;
      color: var(--color-danger);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .meeting-btn-delete:hover {
      background: rgba(255, 107, 107, 0.1);
    }

    /* Quick Add Form */
    .quick-add-form {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 24px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }

    .form-row.full {
      grid-template-columns: 1fr;
    }

    .form-group-inline {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .form-group-inline label {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-secondary);
    }

    .form-group-inline input,
    .form-group-inline select {
      padding: 8px 12px;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-primary);
      font-size: 13px;
      font-family: inherit;
    }

    .form-group-inline input:focus,
    .form-group-inline select:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(226, 245, 0, 0.1);
    }

    .form-actions {
      display: flex;
      gap: 12px;
    }

    .form-btn {
      flex: 1;
      padding: 10px 16px;
      background: var(--color-info);
      border: none;
      border-radius: 6px;
      color: #fff;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .form-btn:hover {
      background: #0970c4;
    }

    .form-btn-cancel {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-primary);
    }

    .form-btn-cancel:hover {
      background: var(--bg-tertiary);
    }

    /* Playbooks View */
    .playbook-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      transition: all 0.3s ease;
    }
    .playbook-card:hover {
      border-color: rgba(226, 245, 0, 0.2);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .playbook-header {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 4px;
    }
    .playbook-icon {
      font-size: 32px;
      flex-shrink: 0;
    }
    .playbook-title-section {
      flex: 1;
    }
    .playbook-name {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .playbook-target {
      font-size: 13px;
      color: var(--text-secondary);
      font-family: 'DM Sans', sans-serif;
    }

    .playbook-steps {
      display: flex;
      flex-direction: column;
      gap: 12px;
      border-top: 1px solid var(--glass-border);
      border-bottom: 1px solid var(--glass-border);
      padding: 12px 0;
    }
    .playbook-step {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }
    .playbook-step-number {
      width: 28px;
      height: 28px;
      min-width: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Anton', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }
    .playbook-step-content {
      flex: 1;
      min-width: 0;
    }
    .playbook-step-title {
      font-weight: 600;
      font-size: 13px;
      color: var(--text-primary);
      margin-bottom: 2px;
    }
    .playbook-step-description {
      font-size: 12px;
      color: var(--text-secondary);
      line-height: 1.4;
    }
    .playbook-step-status {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 4px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      margin-top: 4px;
      display: inline-block;
    }
    .playbook-step-status.active {
      background: rgba(0, 184, 148, 0.2);
      color: #00b894;
    }
    .playbook-step-status.building {
      background: rgba(253, 203, 110, 0.2);
      color: #fdcb6e;
    }
    .playbook-step-status.planned {
      background: rgba(139, 148, 158, 0.2);
      color: var(--text-secondary);
    }
    .playbook-step-status.todo {
      background: rgba(255, 107, 107, 0.2);
      color: #ff6b6b;
    }

    .playbook-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 8px;
    }
    .playbook-owner {
      font-size: 12px;
      color: var(--text-secondary);
    }
    .playbook-owner strong {
      color: var(--text-primary);
      font-weight: 600;
    }
    .playbook-notes {
      font-size: 12px;
      color: var(--text-secondary);
      line-height: 1.5;
      padding-top: 8px;
      border-top: 1px solid var(--glass-border);
    }

    @media (max-width: 768px) {
      .task-quick-add {
        grid-template-columns: 1fr;
      }
      .task-stats-bar {
        grid-template-columns: repeat(2, 1fr);
      }
      .task-meta {
        font-size: 12px;
      }
    }

    /* Detail Panel */
    .detail-panel {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 480px;
      background: var(--bg-secondary);
      border-left: 1px solid var(--border);
      z-index: 999;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
      box-shadow: -8px 0 32px rgba(0, 0, 0, 0.3);
    }

    .detail-panel.active {
      transform: translateX(0);
    }

    .detail-panel-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 24px;
      border-bottom: 1px solid var(--border);
      sticky: top;
      gap: 12px;
    }

    .detail-panel-close {
      background: none;
      border: none;
      color: var(--text-primary);
      font-size: 24px;
      cursor: pointer;
      padding: 0;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .detail-panel-close:hover {
      color: var(--text-secondary);
    }

    .detail-panel-content {
      padding: 24px;
    }

    .detail-logo-large {
      width: 80px;
      height: 80px;
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
      background: var(--bg-tertiary);
      flex-shrink: 0;
    }

    .detail-logo-large img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .detail-company-name {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-primary);
    }

    .detail-pills {
      display: flex;
      gap: 8px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .detail-section {
      margin-bottom: 24px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .detail-section:last-child {
      border-bottom: none;
    }

    .detail-section-title {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      margin-bottom: 12px;
      font-weight: 600;
    }

    .detail-contacts-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .detail-contact-item {
      display: flex;
      flex-direction: column;
      gap: 2px;
      font-size: 13px;
    }

    .detail-contact-name {
      color: var(--text-primary);
      font-weight: 500;
    }

    .detail-contact-email {
      color: var(--text-secondary);
      font-size: 12px;
    }

    .detail-followup {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      background: var(--bg-tertiary);
      border-radius: 8px;
    }

    .detail-followup-date {
      font-size: 14px;
      font-weight: 500;
    }

    .detail-action-btn {
      padding: 6px 12px;
      font-size: 12px;
      background: var(--color-info);
      color: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .detail-action-btn:hover {
      background: #0970c4;
    }

    .detail-notes {
      color: var(--text-secondary);
      font-size: 13px;
      line-height: 1.6;
    }

    .related-emails-section {
      margin-top: 20px;
    }

    .related-email-item {
      padding: 12px;
      background: var(--bg-tertiary);
      border-radius: 8px;
      margin-bottom: 8px;
      cursor: pointer;
      transition: all 0.15s;
      border: 1px solid transparent;
    }

    .related-email-item:hover {
      border-color: var(--border);
      background: #2a2d37;
    }

    .related-email-contact {
      font-size: 12px;
      color: var(--text-secondary);
      margin-bottom: 2px;
    }

    .related-email-subject {
      font-size: 13px;
      color: var(--text-primary);
      font-weight: 500;
      margin-bottom: 4px;
    }

    .related-email-date {
      font-size: 11px;
      color: var(--text-secondary);
    }

    .detail-status-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-right: 6px;
    }

    /* Action Required Banner */
    .action-required-banner {
      display: none;
      background: linear-gradient(135deg, rgba(255, 107, 107, 0.15), rgba(255, 107, 107, 0.05));
      border: 1px solid rgba(255, 107, 107, 0.2);
      border-left: 4px solid var(--color-danger);
      border-radius: 8px;
      padding: 16px 20px;
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }

    .action-required-banner.active {
      display: flex;
    }

    .action-required-content {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .action-required-pulse {
      display: inline-block;
      width: 12px;
      height: 12px;
      background: var(--color-danger);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    .action-required-text {
      font-size: 14px;
      color: var(--text-primary);
      font-weight: 500;
    }

    .action-required-btn {
      padding: 8px 16px;
      font-size: 13px;
      background: var(--color-danger);
      color: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .action-required-btn:hover {
      background: #ff5252;
    }

    /* ===== Daily Briefing (Mission Control) ===== */
    .briefing-header {
      margin-bottom: 24px;
      padding: 20px 24px;
      background: var(--glass-bg, rgba(26, 29, 39, 0.8));
      border: 1px solid var(--border, #30363d);
      border-radius: 12px;
    }
    .briefing-greeting {
      font-family: 'Anton', sans-serif;
      font-size: 32px;
      letter-spacing: 0.04em;
      color: var(--text-primary);
      margin: 0 0 4px;
    }
    .briefing-date {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 14px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 16px;
    }
    .briefing-summary {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      color: var(--text-primary);
      align-items: center;
    }
    .briefing-summary > span {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 6px 14px 6px 6px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-primary);
    }
    .briefing-summary strong {
      font-family: 'Anton', 'DM Sans', sans-serif;
      font-size: 18px;
      line-height: 1;
      letter-spacing: 0.02em;
      min-width: 32px;
      height: 32px;
      padding: 0 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      color: #0f1117;
      background: var(--text-secondary);
      font-weight: 700;
    }
    .briefing-summary .br-stat-overdue strong { background: var(--color-danger); color: #1a0606; }
    .briefing-summary .br-stat-emails strong { background: var(--color-warning); color: #2a1d00; }
    .briefing-summary .br-stat-tasks strong { background: var(--accent); color: #1a1d00; }

    .briefing-card {
      background: var(--glass-bg, rgba(26, 29, 39, 0.8));
      border: 1px solid var(--border, #30363d);
      border-radius: 12px;
      padding: 18px 22px;
      margin-bottom: 16px;
    }
    .briefing-card-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }
    .briefing-card-header h3 {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 18px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-primary);
      margin: 0;
    }
    .briefing-count {
      background: var(--bg-tertiary);
      color: var(--text-secondary);
      border-radius: 999px;
      padding: 2px 10px;
      font-size: 12px;
      font-weight: 700;
      min-width: 22px;
      text-align: center;
    }
    .briefing-count.urgent {
      background: rgba(255, 107, 107, 0.18);
      color: var(--color-danger);
    }
    .briefing-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .briefing-item {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px 12px;
      padding: 12px 14px;
      background: var(--bg-tertiary);
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.15s ease;
      border-left: 3px solid transparent;
    }
    .briefing-item:hover {
      background: var(--bg-secondary);
      transform: translateX(2px);
    }
    .briefing-item.overdue { border-left-color: var(--color-danger); }
    .briefing-item.soon { border-left-color: var(--color-warning); }
    .briefing-item-main {
      display: flex;
      flex-direction: column;
      gap: 3px;
      flex: 1 1 240px;
      min-width: 0;
    }
    .briefing-item-title {
      font-weight: 600;
      font-size: 13px;
      color: var(--text-primary);
      white-space: normal;
      overflow-wrap: break-word;
      word-break: normal;
      hyphens: none;
      line-height: 1.35;
    }
    .briefing-item-sub {
      font-size: 12px;
      color: var(--text-meta);
      font-family: 'DM Sans', sans-serif;
      white-space: normal;
      overflow-wrap: break-word;
      word-break: normal;
      hyphens: none;
      line-height: 1.45;
    }
    .briefing-item-meta {
      font-size: 12px;
      color: var(--text-meta);
      white-space: nowrap;
      font-weight: 700;
      font-family: 'DM Sans', sans-serif;
      flex: 0 0 auto;
      align-self: flex-start;
    }
    .briefing-item-meta.overdue { color: var(--color-danger); }
    .briefing-item-meta.soon { color: var(--color-warning); }
    .briefing-empty {
      padding: 14px;
      text-align: center;
      color: var(--text-secondary);
      font-size: 13px;
      background: rgba(0, 184, 148, 0.05);
      border: 1px dashed rgba(0, 184, 148, 0.2);
      border-radius: 8px;
    }
    .briefing-footer {
      margin-top: 12px;
      text-align: right;
    }
    /* ==== MVP Daily Command Center ==== */
    .cmd-h2 { margin: 24px 0 8px; font-size: 20px; font-weight: 600; }
    .cmd-quickadd { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
    .cmd-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(440px, 1fr));
      gap: 16px;
    }
    @media (max-width: 540px) {
      .cmd-grid { grid-template-columns: 1fr; }
    }
    .briefing-item-action {
      display: flex;
      gap: 6px;
      flex: 0 0 auto;
      flex-wrap: wrap;
      justify-content: flex-end;
      align-self: flex-start;
    }
    .briefing-item-action .btn { white-space: nowrap; }
    @container briefing-list (max-width: 360px) {
      .briefing-item-action {
        flex-basis: 100%;
        justify-content: flex-start;
      }
    }
    .briefing-list { container-type: inline-size; container-name: briefing-list; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .cmd-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      color: #000;
    }

    /* MVP Modal */
    .mvp-modal-backdrop {
      position: fixed; inset: 0; background: rgba(0,0,0,0.6);
      display: flex; align-items: center; justify-content: center;
      z-index: 9999;
    }
    .mvp-modal {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      width: min(540px, 92vw);
      max-height: 86vh;
      overflow: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .mvp-modal-header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }
    .mvp-modal-header h3 { margin: 0; font-size: 16px; font-weight: 600; }
    .mvp-modal-body { padding: 16px 20px; }
    .mvp-form { display: flex; flex-direction: column; gap: 12px; }
    .mvp-field { display: flex; flex-direction: column; gap: 4px; font-size: 13px; color: var(--text-secondary); }
    .mvp-field input, .mvp-field select, .mvp-field textarea {
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      color: var(--text-primary);
      border-radius: 6px;
      padding: 8px 10px;
      font-size: 14px;
      font-family: inherit;
    }
    .mvp-field input:focus, .mvp-field select:focus, .mvp-field textarea:focus {
      outline: none; border-color: var(--color-info);
    }
    .mvp-table {
      width: 100%; border-collapse: collapse; font-size: 13px;
    }
    .mvp-table th, .mvp-table td {
      text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--border);
    }
    .mvp-table th { color: var(--text-secondary); font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; }

    .briefing-footer a {
      color: var(--accent);
      text-decoration: none;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
    }
    .briefing-footer a:hover { opacity: 0.8; }

    /* Inline Date Picker for Follow-up */
    .followup-date-editor {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .followup-date-input {
      padding: 6px 8px;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text-primary);
      font-size: 12px;
      font-family: inherit;
    }

    .followup-date-input:focus {
      outline: none;
      border-color: var(--accent);
    }

    .followup-date-save {
      padding: 4px 8px;
      font-size: 11px;
      background: var(--color-success);
      color: #fff;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .followup-date-save:hover {
      background: #00a372;
    }

    .followup-date-cancel {
      padding: 4px 8px;
      font-size: 11px;
      background: var(--bg-tertiary);
      color: var(--text-secondary);
      border: 1px solid var(--border);
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .followup-date-cancel:hover {
      background: #2a2d37;
    }

    /* Schools Board */
    .schools-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 20px;
    }

    .schools-header h2 {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 30px;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .schools-subtitle {
      color: var(--text-secondary);
      font-size: 14px;
    }

    .schools-stats {
      display: grid;
      grid-template-columns: repeat(5, minmax(120px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }

    .schools-stat-card {
      background: linear-gradient(180deg, rgba(35, 39, 51, 0.95), rgba(20, 22, 29, 0.95));
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      min-width: 0;
    }

    .schools-stat-value {
      font-family: 'Anton', sans-serif;
      font-size: 28px;
      color: var(--accent);
      line-height: 1;
      margin-bottom: 8px;
    }

    .schools-stat-label {
      font-size: 11px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    .schools-control-bar {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
    }

    .schools-filters,
    .schools-view-toggle {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }

    .schools-filter-chip,
    .schools-view-btn {
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--bg-secondary);
      color: var(--text-secondary);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .schools-filter-chip.active,
    .schools-view-btn.active {
      background: var(--accent);
      color: #000;
      border-color: var(--accent);
    }

    .schools-search {
      min-width: 240px;
      flex: 1;
      max-width: 320px;
      padding: 10px 14px;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-primary);
      font-size: 13px;
    }

    .schools-search:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(226, 245, 0, 0.08);
    }

    .schools-group {
      margin-bottom: 28px;
    }

    .schools-group-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .schools-group-title {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 24px;
      letter-spacing: 0.8px;
      text-transform: uppercase;
    }

    .schools-group-meta {
      color: var(--text-secondary);
      font-size: 12px;
    }

    .conference-section {
      margin-bottom: 24px;
      padding: 18px;
      background: rgba(15, 17, 23, 0.7);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
    }

    .conference-section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 14px;
    }

    .conference-title-block {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .conference-name {
      font-family: 'Saira Extra Condensed', sans-serif;
      font-size: 22px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    .conference-badge {
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(226, 245, 0, 0.12);
      color: var(--accent);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    .conference-metrics {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .conference-metric {
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--bg-secondary);
      color: var(--text-secondary);
      font-size: 11px;
      border: 1px solid rgba(255,255,255,0.06);
    }

    .schools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 12px;
    }

    .school-card {
      border-radius: 16px;
      padding: 14px;
      min-height: 165px;
      background: linear-gradient(180deg, rgba(30, 34, 45, 0.95), rgba(20, 22, 29, 0.95));
      border: 1px solid rgba(255,255,255,0.07);
      display: flex;
      flex-direction: column;
      gap: 10px;
      cursor: pointer;
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
      position: relative;
      overflow: hidden;
    }

    .school-card:hover {
      transform: translateY(-2px);
      border-color: rgba(226, 245, 0, 0.35);
      box-shadow: 0 16px 32px rgba(0, 0, 0, 0.24);
    }

    .school-card.unworked {
      opacity: 0.82;
      background: linear-gradient(180deg, rgba(26, 29, 39, 0.9), rgba(17, 19, 26, 0.9));
    }

    .school-card.client {
      border-color: rgba(226, 245, 0, 0.45);
      box-shadow: inset 0 0 0 1px rgba(226, 245, 0, 0.18);
    }

    .school-card-header {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: flex-start;
    }

    .school-logo {
      width: 46px;
      height: 46px;
      border-radius: 14px;
      background: rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-primary);
      overflow: hidden;
      flex-shrink: 0;
    }

    .school-logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      background: rgba(255,255,255,0.02);
    }

    .school-conference-pill {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.7px;
      color: var(--text-secondary);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 999px;
      padding: 4px 8px;
      background: rgba(255,255,255,0.03);
      white-space: nowrap;
    }

    .school-name {
      font-size: 14px;
      font-weight: 700;
      line-height: 1.25;
      color: var(--text-primary);
      min-height: 36px;
    }

    .school-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      width: fit-content;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.7px;
      background: rgba(255,255,255,0.08);
      color: var(--text-secondary);
    }

    .school-status.unworked {
      background: rgba(139, 148, 158, 0.14);
      color: var(--text-secondary);
    }

    .school-heat {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      width: fit-content;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.7px;
    }

    .school-heat.green {
      background: rgba(0, 184, 148, 0.16);
      color: #7ef0cc;
    }

    .school-heat.yellow {
      background: rgba(253, 203, 110, 0.16);
      color: #ffe08f;
    }

    .school-heat.red {
      background: rgba(255, 107, 107, 0.16);
      color: #ff9d9d;
    }

    .school-heat-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
    }

    .school-context {
      color: var(--text-secondary);
      font-size: 12px;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      min-height: 54px;
    }

    .school-card-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin-top: auto;
      font-size: 11px;
      color: var(--text-secondary);
    }

    .schools-empty {
      padding: 24px;
      border-radius: 14px;
      background: rgba(255,255,255,0.03);
      border: 1px dashed rgba(255,255,255,0.08);
      color: var(--text-secondary);
      text-align: center;
      font-size: 13px;
    }

    .school-panel-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      margin-top: 20px;
    }

    @media (max-width: 1200px) {
      .schools-stats {
        grid-template-columns: repeat(3, minmax(120px, 1fr));
      }
    }

    @media (max-width: 1024px) {
      .detail-panel {
        width: 100%;
      }

      .schools-header,
      .schools-control-bar,
      .conference-section-header {
        flex-direction: column;
        align-items: stretch;
      }

      .schools-stats {
        grid-template-columns: repeat(2, minmax(120px, 1fr));
      }
    }
