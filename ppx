  const data = {};
  return {
    read: function (k) { return Promise.resolve(data[k] != null ? JSON.parse(JSON.stringify(data[k])) : null); },
    write: function (k, v) { data[k] = JSON.parse(JSON.stringify(v)); return Promise.resolve(); },
    dump: function () { return data; }
  };
}

