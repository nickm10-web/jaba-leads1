    // Smart add: parse natural language task input
    window.smartAddTask = function() {
      const input = document.getElementById('taskQuickInput');
      const text = input.value.trim();
      if (!text) return;

      const newId = tasks.length > 0 ? Math.max(...tasks.map(t => t.id)) + 1 : 1;

      // Try to detect a lead name
      let linkedLeadId = null;
      let matchedLead = null;
      leads.forEach(lead => {
        if (text.toLowerCase().includes(lead.company.toLowerCase())) {
          linkedLeadId = lead.id;
          matchedLead = lead;
        }
      });
      // Also try matching contact names from INBOX_EMAILS
      if (!linkedLeadId) {
        INBOX_EMAILS.forEach(e => {
          const names = e.contact.toLowerCase().split(' ');
          if (names.some(n => n.length > 3 && text.toLowerCase().includes(n))) {
            const lead = leads.find(l => l.company.toLowerCase().includes(e.company.toLowerCase()));
            if (lead) { linkedLeadId = lead.id; matchedLead = lead; }
          }
        });
      }

      // Detect due date from text
      let dueDate = getFutureDate(1); // default tomorrow
      const lower = text.toLowerCase();
      if (lower.includes('today')) dueDate = getTodayDate();
      else if (lower.includes('tomorrow')) dueDate = getFutureDate(1);
      else if (lower.includes('monday')) dueDate = getNextDay(1);
      else if (lower.includes('tuesday')) dueDate = getNextDay(2);
      else if (lower.includes('wednesday')) dueDate = getNextDay(3);
      else if (lower.includes('thursday')) dueDate = getNextDay(4);
      else if (lower.includes('friday')) dueDate = getNextDay(5);
      else if (lower.includes('next week')) dueDate = getFutureDate(7);
      else if (lower.includes('this week')) dueDate = getFutureDate(3);

      // Detect priority
      let priority = 'medium';
      if (lower.includes('urgent') || lower.includes('asap') || lower.includes('important')) priority = 'high';

      const task = {
        id: newId,
        title: text,
        dueDate,
        priority,
        status: 'todo',
        linkedLeadId,
        notes: matchedLead ? ('Linked to ' + matchedLead.company) : '',
        createdDate: getTodayDate()
      };

      tasks.push(task);
      saveTasks();
      renderTasks();
      input.value = '';
      input.focus();
    };

    function getNextDay(dayOfWeek) {
      // 0=Sun, 1=Mon, etc
      const today = new Date();
      const todayDay = today.getDay();
      let daysUntil = dayOfWeek - todayDay;
      if (daysUntil <= 0) daysUntil += 7;
      const target = new Date(today);
      target.setDate(target.getDate() + daysUntil);
      return target.toISOString().split('T')[0];
    }

