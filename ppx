      let html = '';
      if (overdue.length > 0) {
        html += `<div class="inbox-section">
          <div class="inbox-section-title danger">Needs Follow-Up (${overdue.length})</div>
          ${overdue.sort((a,b)=>a.daysSince-b.daysSince).map(renderEmailItem).join('')}
        </div>`;
      }
      if (pending.length > 0) {
        html += `<div class="inbox-section">
          <div class="inbox-section-title warning">Sent Recently / Waiting (${pending.length})</div>
