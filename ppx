    function getCleanThreads() {
      const raw = Object.values(gmailThreadCache);
      // Filter out nulls, empty threads, and noise
      return raw
        .filter(t => t && t.email && t.messages && Array.isArray(t.messages) && t.messages.length > 0)
        .filter(t => {
          const e = t.email.toLowerCase();
          return !e.includes('noreply') && !e.includes('no-reply') && !e.includes('calendar-notification')
            && !e.includes('notifications@') && !e.includes('mailer-daemon') && !e.includes('postmaster')
            && !e.includes('donotreply') && !e.includes('notify') && !e.includes('updates@');
        })
        .map(t => {
          const msgs = [...t.messages].filter(m => m && m.timestamp).sort((a, b) => b.timestamp - a.timestamp);
          return { ...t, messages: msgs, latest: msgs[0] || null };
        })
        .filter(t => t.latest)
        .sort((a, b) => b.latest.timestamp - a.latest.timestamp);
    }

    function renderGmailInbox() {
      const container = document.getElementById('inboxGmail');
      const all = getCleanThreads();

      if (all.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-secondary);">No Gmail data yet. Waiting for Apps Script sync...</div>';
        return;
      }

      let filtered = all;
      if (currentGmailTab === 'received') {
        filtered = all.filter(t => !t.latest.isSent);
      } else if (currentGmailTab === 'sent') {
        filtered = all.filter(t => t.latest.isSent);
      } else if (currentGmailTab === 'needsreply') {
        filtered = all.filter(t => {
          const latestReceived = t.messages.find(m => !m.isSent);
          const latestSent = t.messages.find(m => m.isSent);
          return latestReceived && (!latestSent || latestReceived.timestamp > latestSent.timestamp);
        });
      }

      renderThreadList(filtered, container);
    }

    function renderThreadList(sorted, container) {
      const rows = [];
      sorted.forEach(thread => {
        try {
          const latest = thread.latest;
          if (!latest || !latest.timestamp || latest.timestamp < 1000000000000) return;
          if (!thread.email && !thread.contact) return;

          const subject = safeDecode(latest.subject) || '';
          const snippet = safeDecode(latest.snippet) || '';
          if (!subject && !snippet) return;

          const msgCount = thread.messages.length;
          const displayName = cleanContactName(thread.contact, thread.email);
          if (!displayName || displayName === '?' || displayName.trim().length === 0) return;
          const initials = displayName.split(' ').filter(w => w.length > 0).map(w => w[0]).join('').toUpperCase().substring(0, 2) || '?';

          const crmLead = findLeadForThread(thread.email);
          const logoUrl = crmLead ? crmLead.domain : null;

          const date = new Date(latest.timestamp);
          if (isNaN(date.getTime())) return;
          const now = new Date();
          const diffDays = Math.floor((now - date) / (1000*60*60*24));
          let dateStr;
          if (diffDays === 0) dateStr = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
          else if (diffDays === 1) dateStr = 'Yesterday';
          else if (diffDays < 7) dateStr = date.toLocaleDateString('en-US', { weekday: 'short' });
          else dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

          const latestReceived = thread.messages.find(m => !m.isSent);
          const latestSent = thread.messages.find(m => m.isSent);
          const ballInOurCourt = latestReceived && (!latestSent || latestReceived.timestamp > latestSent.timestamp);
          const needsFollowUp = !ballInOurCourt && diffDays >= 4 && latestSent && (!latestReceived || latestSent.timestamp > latestReceived.timestamp);

          let statusDot = '';
          if (ballInOurCourt) statusDot = '<span style="width:8px;height:8px;border-radius:50%;background:#00b894;display:inline-block;margin-right:6px;" title="Needs response"></span>';
          else if (needsFollowUp) statusDot = '<span style="width:8px;height:8px;border-radius:50%;background:#ff6b6b;display:inline-block;margin-right:6px;" title="Needs follow-up"></span>';

          const avatarBg = ballInOurCourt ? '#00b894' : needsFollowUp ? '#ff6b6b' : 'var(--bg-tertiary)';
          const avatarColor = (ballInOurCourt || needsFollowUp) ? '#fff' : 'var(--text-secondary)';
          const borderColor = ballInOurCourt ? '#00b894' : needsFollowUp ? '#ff6b6b' : 'var(--border)';

          let avatarHtml;
          if (logoUrl) {
            avatarHtml = `<div style="width:36px;height:36px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2px solid ${borderColor};background:var(--bg-tertiary);display:flex;align-items:center;justify-content:center;">
              <img src="${logoUrl}" style="width:28px;height:28px;object-fit:contain;" onerror="this.style.display='none';this.parentElement.textContent='${initials}';">
            </div>`;
          } else {
            avatarHtml = `<div style="width:36px;height:36px;border-radius:50%;background:${avatarBg};display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:${avatarColor};flex-shrink:0;">${initials}</div>`;
          }

          const companyName = safeHtml(crmLead ? crmLead.company : (thread.company || ''));
          const safeDisplayName = safeHtml(displayName);
          const safeThreadId = (thread.threadId || '').replace(/'/g, "\\'");
          const lastWasSent = latest.isSent;
          const sentIndicator = lastWasSent ? '<span style="font-size:10px;color:var(--text-secondary);margin-right:2px;">↩</span>' : '';

          rows.push(`<div onclick="openThreadView('${safeThreadId}')" style="display:flex;align-items:center;gap:14px;padding:12px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.15s;flex-shrink:0;" onmouseover="this.style.background='var(--bg-tertiary)'" onmouseout="this.style.background='transparent'">
            ${avatarHtml}
            <div style="flex:1;min-width:0;">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;">
                <div style="display:flex;align-items:center;gap:4px;min-width:0;overflow:hidden;">
                  ${statusDot}${sentIndicator}
                  <span style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${safeDisplayName}</span>
                  ${msgCount > 1 ? '<span style="font-size:11px;color:var(--text-secondary);flex-shrink:0;">(' + msgCount + ')</span>' : ''}
                  ${companyName ? '<span style="font-size:11px;color:var(--accent);flex-shrink:0;margin-left:4px;">&bull; ' + companyName + '</span>' : ''}
                </div>
                <span style="font-size:11px;color:var(--text-secondary);flex-shrink:0;margin-left:8px;">${dateStr}</span>
              </div>
              <div style="font-size:13px;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${subject || '(no subject)'}</div>
              <div style="font-size:12px;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px;">${snippet}</div>
            </div>
          </div>`);
        } catch(e) {
          // Skip any thread that errors during rendering
        }
      });

      container.innerHTML = rows.length > 0 ? rows.join('') : '<div style="text-align:center;padding:40px;color:var(--text-secondary);">No threads found.</div>';
    }

    function categorizeEmail(item) {
      // Manual override from drag-drop takes precedence
      if (item.pipelineOverride) return item.pipelineOverride;
      // 1. Meeting scheduled (explicit category or note mentions meeting)
      if (item.category === 'meeting') return 'meeting';
      if (item.status === 'replied' && item.note && (item.note.toLowerCase().includes('meeting') || item.note.toLowerCase().includes('call week') || item.note.toLowerCase().includes('meeting confirmed') || item.note.toLowerCase().includes('scheduling call'))) return 'meeting';

      // 2. Needs Response - they replied, ball in our court
      if (item.note && (item.note.includes('NEEDS REPLY') || item.note.includes('Ball in our court'))) return 'needs_response';
      if (item.status === 'replied' && item.daysSince <= 3) return 'needs_response';

      // 3. Needs Response - they replied, ball in our court
      if (item.status === 'replied') return 'needs_response';

      // 4. Needs Follow-Up - we sent, 4+ days no reply
      if (item.status === 'overdue') return 'needs_followup';
      if (item.status === 'pending' && item.daysSince >= 4) return 'needs_followup';

      // 5. Waiting on Response - we sent recently, < 4 days
      if (item.status === 'pending') return 'waiting';
      if (item.status === 'waiting') return 'waiting';

      // Fallback
      return 'waiting';
    }

    // Recompute daysSince and auto-escalate stale statuses for all inbox emails.
    // Call this before any code reads INBOX_EMAILS to keep data fresh.
    function refreshInboxDates() {
      const today = new Date();
      INBOX_EMAILS.forEach(e => {
        if (!e || !e.sentDate) return;
        const sent = new Date(e.sentDate + 'T00:00:00');
        e.daysSince = Math.floor((today - sent) / (1000*60*60*24));
        // Auto-escalate pending/waiting → overdue after 4 days with no reply
        if ((e.status === 'pending' || e.status === 'waiting') && e.daysSince >= 4) {
          e.status = 'overdue';
        }
      });
    }

    function renderInbox() {
      const inboxList = document.getElementById('inboxList');

      // Refresh dates before rendering
      refreshInboxDates();

      // Load any saved overrides before categorizing
      loadInboxOverrides();

      // Categorize all emails using the pipeline logic
      const recentAll = INBOX_EMAILS.filter(e => e && e.daysSince <= 60 && !e.dismissed);
      const waitingEmails = recentAll.filter(e => categorizeEmail(e) === 'waiting');
      const needsFollowup = recentAll.filter(e => categorizeEmail(e) === 'needs_followup');
      const needsResponse = recentAll.filter(e => categorizeEmail(e) === 'needs_response');
      const meetingEmails = recentAll.filter(e => categorizeEmail(e) === 'meeting');

      document.getElementById('inboxPending').textContent = waitingEmails.length;
      document.getElementById('inboxOverdue').textContent = needsFollowup.length;
      document.getElementById('inboxReplied').textContent = needsResponse.length;
      // Meeting count updated after meetings are injected into kanban (below)

      // Keep these for the list view
      const overdue = INBOX_EMAILS.filter(e => e && e.status === 'overdue');
      const pending = INBOX_EMAILS.filter(e => e && e.status === 'pending');
      const replied = INBOX_EMAILS.filter(e => e && e.status === 'replied');

      // Try to match email to CRM lead for logo
      function findLead(company) {
        return leads.find(l => l.company.toLowerCase().includes(company.toLowerCase()) || company.toLowerCase().includes(l.company.toLowerCase()));
      }

      function daysText(d) { return d === 0 ? 'Today' : d === 1 ? '1d ago' : d + 'd ago'; }
      function daysClass(d) { return d >= 7 ? 'urgent' : d >= 4 ? 'warn' : 'ok'; }
      function statusLabel(item) {
        const cat = categorizeEmail(item);
        if (cat === 'waiting') return { text: 'Waiting', cls: 'waiting' };
        if (cat === 'needs_followup') return { text: 'Needs Follow-Up', cls: 'needs-reply' };
        if (cat === 'needs_response') return { text: 'Needs Response', cls: 'active' };
        if (cat === 'meeting') return { text: 'Meeting Set', cls: 'meeting' };
        return { text: 'Waiting', cls: 'waiting' };
      }

      // ===== KANBAN VIEW =====
      const kanbanCols = {
        waiting: { title: 'Waiting on Response', cls: 'waiting', items: [] },
        needs_followup: { title: 'Needs Follow-Up', cls: 'needs-reply', items: [] },
        needs_response: { title: 'Needs Response', cls: 'active-conv', items: [] },
        meeting: { title: 'Meeting Scheduled', cls: 'meeting-set', items: [] }
      };

      // Only show recent/relevant items in kanban (last 60 days)
      const recentEmails = INBOX_EMAILS.filter(e => e && e.daysSince <= 60 && !e.dismissed);
      recentEmails.forEach(e => {
        const cat = categorizeEmail(e);
        if (kanbanCols[cat]) kanbanCols[cat].items.push(e);
      });

      // Also inject upcoming meetings from the meetings array into Meeting Scheduled column
      const todayStr = getTodayDate();
      const upcomingMeetings = meetings.filter(m => m.date >= todayStr && m.status !== 'completed');
      upcomingMeetings.forEach(m => {
        // Check if this meeting is already in the column (from INBOX_EMAILS)
        const alreadyIn = kanbanCols.meeting.items.some(e =>
          e.company && m.company && e.company.toLowerCase() === m.company.toLowerCase() && e.category === 'meeting'
        );
        if (!alreadyIn) {
          const meetDate = new Date(m.date + 'T00:00:00');
          const daysSince = Math.floor((new Date() - meetDate) / (1000*60*60*24));
          kanbanCols.meeting.items.push({
            contact: m.contact || m.attendees?.[0] || '',
            company: m.company || '',
            email: '',
            subject: m.title || (m.company + ' Meeting'),
            sentDate: m.date,
            daysSince: Math.abs(daysSince),
            status: 'meeting',
            category: 'meeting',
            note: (m.time || '') + (m.location ? ' - ' + m.location : ''),
            isMeeting: true,
            meetingId: m.id
          });
        }
      });

      // Update meeting count now that calendar meetings are included
      document.getElementById('inboxMeetings').textContent = kanbanCols.meeting.items.length;

      let kanbanHtml = '';
