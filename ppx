<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="background:var(--accent);color:#000;font-family:'Anton',sans-serif;font-size:20px;padding:6px 14px;border-radius:8px;letter-spacing:1px;">JABA</div>
        <div>
          <h1 style="font-family:'Saira Extra Condensed',sans-serif;font-size:28px;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Control Center</h1>
          <div style="font-size:12px;color:var(--text-secondary);">Built Different — Business Development</div>
        </div>
      </div>
      <div class="header-actions">
        <span id="mvpPersistenceStatus" role="status" aria-live="polite" aria-label="CRM sync status" title="CRM sync status" style="display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600;background:rgba(255,255,255,0.06);color:#999;border:1px solid rgba(255,255,255,0.08);"><span id="mvpPersistenceDot" aria-hidden="true" style="width:8px;height:8px;border-radius:50%;background:#999;display:inline-block;flex-shrink:0;"></span><span id="mvpPersistenceLabel">Connecting…</span></span>
        <span id="inboxSyncStatus" role="status" aria-live="polite" title="Inbox sync status" style="display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:500;background:rgba(255,255,255,0.04);color:#bbb;border:1px solid rgba(255,255,255,0.06);">Inbox: never synced</span>
        <button class="btn btn-secondary" id="inboxSyncBtn" onclick="window.jabaInboxSync && window.jabaInboxSync.run()">Sync Inbox</button>
        <button class="btn btn-secondary" onclick="exportData()">Export</button>
        <button class="btn btn-secondary" onclick="jabaMvp.openSlackLeadForm()">+ Slack/Text Lead</button>
        <button class="btn btn-secondary" onclick="jabaMvp.openSmartleadForm()">+ Smartlead Reply</button>
        <button class="btn btn-secondary" onclick="jabaMvp.openMeetingNoteForm()">+ Meeting Note</button>
        <button class="btn btn-secondary" onclick="jabaMvp.openFollowUpForm()">+ Follow-up</button>
        <button class="btn" style="background:var(--accent);color:#000;font-weight:600;" onclick="showAddModal()">+ Add Lead</button>
      </div>
    </div>

    <!-- Top-Level Tabs -->
    <div class="top-tabs">
      <button class="top-tab active" data-section="dashboard" onclick="switchSection('dashboard')">Dashboard</button>
      <button class="top-tab" data-section="leads" onclick="switchSection('leads')">Leads <span class="tab-badge" id="leadsBadge" style="background:var(--accent);color:#000;">0</span></button>
      <button class="top-tab" data-section="schools" onclick="switchSection('schools')">Schools</button>
      <button class="top-tab" data-section="inbox" onclick="switchSection('inbox')">Inbox <span class="tab-badge" id="inboxBadge">0</span></button>
      <button class="top-tab" data-section="meetings" onclick="switchSection('meetings')">Meetings <span class="tab-badge" id="meetingsBadge">0</span></button>
      <button class="top-tab" data-section="tasks" onclick="switchSection('tasks')">Tasks <span class="tab-badge" id="tasksBadge">0</span></button>
      <button class="top-tab" data-section="crmMvp" onclick="switchSection('crmMvp')">CRM</button>
      <button class="top-tab" data-section="playbooks" onclick="switchSection('playbooks')">Playbooks</button>
    </div>

    <!-- DASHBOARD SECTION (Daily Briefing / Mission Control) -->
    <div id="dashboardSection">
