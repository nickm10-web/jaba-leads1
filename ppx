      const footer = document.getElementById('brFollowUpsFooter');
      if (!list) return;
      count.textContent = items.length;
      count.classList.toggle('urgent', items.length > 0);
      if (items.length === 0) {
        list.innerHTML = '<div class="briefing-empty">No overdue follow-ups. Caught up.</div>';
        footer.innerHTML = '';
        return;
      }
      const limit = BR_STATE.followUpsExpanded ? items.length : 5;
      const shown = items.slice(0, limit);
      list.innerHTML = shown.map(f => {
        const overdueLabel = f.daysOverdue + 'd overdue';
