    // Clean up contact name
    function cleanContactName(rawName, email) {
      // 1. Check INBOX_EMAILS for a match by email
      if (email) {
        const match = INBOX_EMAILS.find(e => e && e.email && e.email.toLowerCase() === email.toLowerCase());
        if (match && match.contact) return match.contact;
      }
      // 2. Check CRM leads contacts list for email match
      if (email) {
        const lead = leads.find(l => l.contacts && l.contacts.some(c => c.toLowerCase().includes(email.toLowerCase())));
        if (lead) {
          const contactStr = lead.contacts.find(c => c.toLowerCase().includes(email.toLowerCase()));
          const nameMatch = contactStr ? contactStr.match(/^([^(]+)/) : null;
          if (nameMatch) return nameMatch[1].trim();
        }
      }
      // 3. If rawName has commas, take just the first name
      if (rawName && rawName.includes(',')) {
        rawName = rawName.split(',')[0].trim();
      }
      // 4. Check if rawName is actually a proper name (has space, no @, no digits)
      if (rawName && rawName.includes(' ') && !rawName.includes('@') && !/\d/.test(rawName)) {
        return rawName;
      }
      // 5. If rawName looks like an email handle, try to make it readable
      if (rawName && !rawName.includes(' ')) {
        const cleaned = rawName.replace(/@.*$/, '').replace(/[0-9._]/g, ' ').trim();
        if (cleaned.length > 1) {
          return cleaned.split(' ').filter(Boolean).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
        }
      }
      // 6. Fall back to email prefix
      if (email) {
        const prefix = email.split('@')[0].replace(/[._]/g, ' ');
        return prefix.split(' ').filter(Boolean).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      }
      return rawName || '?';
    }

    // Find CRM lead matching a thread by email domain
    function findLeadForThread(email) {
      if (!email) return null;
      const domain = email.split('@')[1];
      if (!domain) return null;
      // Direct email match in CRM contacts
      let lead = leads.find(l => l.contacts && l.contacts.some(c => c.toLowerCase().includes(email.toLowerCase())));
      if (lead) return lead;
      // Domain match (e.g. uw.edu -> Washington)
      lead = leads.find(l => l.contacts && l.contacts.some(c => {
        const m = c.match(/<([^>]+)>|\(([^)]+@[^)]+)\)/);
        const contactEmail = m ? (m[1] || m[2]) : '';
        return contactEmail && contactEmail.split('@')[1] === domain;
      }));
      return lead || null;
    }

